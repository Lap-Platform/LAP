{
  "name": "brave-search",
  "description": "MCP server for Brave Search API",
  "tools": [
    {
      "name": "brave_web_search",
      "description": "Search the web using Brave Search API",
      "inputSchema": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {"type": "string", "description": "Search query"},
          "count": {"type": "integer", "description": "Number of results (1-20)", "default": 10},
          "offset": {"type": "integer", "description": "Pagination offset"},
          "country": {"type": "string", "description": "Country code (e.g. US, GB, DE)"},
          "search_lang": {"type": "string", "description": "Search language (e.g. en, de, fr)"},
          "freshness": {"type": "string", "enum": ["pd", "pw", "pm", "py"], "description": "Time filter: past day/week/month/year"},
          "safesearch": {"type": "string", "enum": ["off", "moderate", "strict"], "description": "Safe search level"}
        }
      }
    },
    {
      "name": "brave_local_search",
      "description": "Search for local businesses and places",
      "inputSchema": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {"type": "string", "description": "Local search query (e.g. 'pizza near me')"},
          "count": {"type": "integer", "description": "Number of results", "default": 5}
        }
      }
    }
  ]
}
