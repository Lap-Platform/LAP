@endpoint GET /account
@returns(200) {active_promotions: [map], active_since: str(date-time), address_1: str, address_2: str, balance: num, balance_uninvoiced: num, billing_source: str, capabilities: [str], city: str, company: str, country: str, credit_card: map{expiry: str, last_four: str}, email: str, euuid: str(uuid), first_name: str, last_name: str, phone: str, state: str, tax_id: str, zip: str}

@endpoint PUT /account
@optional {active_promotions: [map], active_since: str(date-time), address_1: str, address_2: str, balance: num, balance_uninvoiced: num, billing_source: str(akamai/linode), capabilities: [str], city: str, company: str, country: str, credit_card: map, email: str, euuid: str(uuid), first_name: str, last_name: str, phone: str, state: str, tax_id: str, zip: str}
@returns(200) {active_promotions: [map], active_since: str(date-time), address_1: str, address_2: str, balance: num, balance_uninvoiced: num, billing_source: str, capabilities: [str], city: str, company: str, country: str, credit_card: map{expiry: str, last_four: str}, email: str, euuid: str(uuid), first_name: str, last_name: str, phone: str, state: str, tax_id: str, zip: str}

@endpoint POST /account/cancel
@optional {comments: str}
@returns(200) {survey_link: str}
@errors {409}

@endpoint POST /account/credit-card
@required {card_number: str(digits), cvv: str(digits), expiry_month: int, expiry_year: int}
@returns(200)

@endpoint GET /account/entity-transfers
@optional {page: int=1, page_size: int=100}
@returns(200)

@endpoint POST /account/entity-transfers
@required {entities: map}
@returns(200) {created: str(date-time), entities: map{linodes: [int]}, expiry: str(date-time), is_sender: bool, status: str, token: str(uuid), updated: str(date-time)}

@endpoint DELETE /account/entity-transfers/{token}
@returns(200)

@endpoint GET /account/entity-transfers/{token}
@returns(200) {created: str(date-time), entities: map{linodes: [int]}, expiry: str(date-time), is_sender: bool, status: str, token: str(uuid), updated: str(date-time)}

@endpoint POST /account/entity-transfers/{token}/accept
@returns(200)

@endpoint GET /account/events
@optional {page: int=1, page_size: int=100}
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint GET /account/events/{eventId}
@returns(200) {action: str, created: str(date-time), duration: num, entity: map{id: int, label: str, type: str, url: str}, id: int, message: str?, percent_complete: int, rate: str, read: bool, secondary_entity: map{id: str, label: str, type: str, url: str}, seen: bool, status: str, time_remaining: str?, username: str?}

@endpoint POST /account/events/{eventId}/read
@returns(200)

@endpoint POST /account/events/{eventId}/seen
@returns(200)

@endpoint GET /account/invoices
@optional {page: int=1, page_size: int=100}
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint GET /account/invoices/{invoiceId}
@returns(200) {date: str(date-time), id: int, label: str, subtotal: num, tax: num, tax_summary: [map], total: num}

@endpoint GET /account/invoices/{invoiceId}/items
@optional {page: int=1, page_size: int=100}
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint GET /account/logins
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint GET /account/logins/{loginId}
@returns(200) {datetime: str(date-time), id: int, ip: str(ip), restricted: bool, username: str}

@endpoint GET /account/maintenance
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint GET /account/notifications
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint GET /account/oauth-clients
@optional {page: int=1, page_size: int=100}
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint POST /account/oauth-clients
@returns(200) {id: str, label: str, public: bool, redirect_uri: str(url), secret: str, status: str, thumbnail_url: str(url)?}

@endpoint DELETE /account/oauth-clients/{clientId}
@returns(200)

@endpoint GET /account/oauth-clients/{clientId}
@returns(200) {id: str, label: str, public: bool, redirect_uri: str(url), secret: str, status: str, thumbnail_url: str(url)?}

@endpoint PUT /account/oauth-clients/{clientId}
@optional {id: str, label: str, public: bool=False, redirect_uri: str(url), secret: str, status: str(active/disabled/suspended), thumbnail_url: str(url)}
@returns(200) {id: str, label: str, public: bool, redirect_uri: str(url), secret: str, status: str, thumbnail_url: str(url)?}

@endpoint POST /account/oauth-clients/{clientId}/reset-secret
@returns(200) {id: str, label: str, public: bool, redirect_uri: str(url), secret: str, status: str, thumbnail_url: str(url)?}

@endpoint GET /account/oauth-clients/{clientId}/thumbnail
@returns(200)

@endpoint PUT /account/oauth-clients/{clientId}/thumbnail
@returns(200)

@endpoint GET /account/payment-methods
@optional {page: int=1, page_size: int=100}
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint POST /account/payment-methods
@required {data: map, is_default: bool, type: str}
@returns(200)

@endpoint DELETE /account/payment-methods/{paymentMethodId}
@returns(200)

@endpoint GET /account/payment-methods/{paymentMethodId}
@returns(200) {created: str(date-time), data: any, id: int, is_default: bool, type: str}

@endpoint POST /account/payment-methods/{paymentMethodId}/make-default
@returns(200)

@endpoint GET /account/payments
@optional {page: int=1, page_size: int=100}
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint POST /account/payments
@required {usd: str}
@optional {cvv: str, payment_method_id: int}
@returns(200) {date: str(date-time), id: int, usd: int}
@returns(202) {warnings: [map]}

@endpoint POST /account/payments/paypal
@required {cancel_url: str, redirect_url: str, usd: str}
@returns(200) {checkout_token: str, payment_id: str}
@returns(299) {warnings: [map]}

@endpoint POST /account/payments/paypal/execute
@required {payer_id: str, payment_id: str}
@returns(200)
@returns(202) {warnings: [map]}
@returns(299) {warnings: [map]}

@endpoint GET /account/payments/{paymentId}
@returns(200) {date: str(date-time), id: int, usd: int}

@endpoint POST /account/promo-codes
@required {promo_code: str}
@returns(200) {credit_monthly_cap: str, credit_remaining: str, description: str, expire_dt: str, image_url: str, service_type: str, summary: str, this_month_credit_remaining: str}

@endpoint GET /account/service-transfers
@optional {page: int=1, page_size: int=100}
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint POST /account/service-transfers
@required {entities: map}
@returns(200) {created: str(date-time), entities: map{linodes: [int]}, expiry: str(date-time), is_sender: bool, status: str, token: str(uuid), updated: str(date-time)}

@endpoint DELETE /account/service-transfers/{token}
@returns(200)

@endpoint GET /account/service-transfers/{token}
@returns(200) {created: str(date-time), entities: map{linodes: [int]}, expiry: str(date-time), is_sender: bool, status: str, token: str(uuid), updated: str(date-time)}

@endpoint POST /account/service-transfers/{token}/accept
@returns(200)

@endpoint GET /account/settings
@returns(200) {backups_enabled: bool, longview_subscription: str, managed: bool, network_helper: bool, object_storage: str}

@endpoint PUT /account/settings
@optional {backups_enabled: bool, longview_subscription: str, managed: bool, network_helper: bool, object_storage: str(disabled/suspended/active)=disabled}
@returns(200) {backups_enabled: bool, longview_subscription: str, managed: bool, network_helper: bool, object_storage: str}

@endpoint POST /account/settings/managed-enable
@returns(200)

@endpoint GET /account/transfer
@returns(200) {billable: int, quota: int, used: int}

@endpoint GET /account/users
@optional {page: int=1, page_size: int=100}
@returns(200) {data: [map], page: int, pages: int, results: int}

@endpoint POST /account/users
@returns(200) {email: str(email), restricted: bool, ssh_keys: [str], tfa_enabled: bool, username: str}

@endpoint DELETE /account/users/{username}
@returns(200)

@endpoint GET /account/users/{username}
@returns(200) {email: str(email), restricted: bool, ssh_keys: [str], tfa_enabled: bool, username: str}

@endpoint PUT /account/users/{username}
@optional {email: str(email), restricted: bool, ssh_keys: [str], tfa_enabled: bool, username: str}
@returns(200) {email: str(email), restricted: bool, ssh_keys: [str], tfa_enabled: bool, username: str}

@endpoint GET /account/users/{username}/grants
@returns(200) {database: [map], domain: [map], global: map{account_access: str?, add_databases: bool, add_domains: bool, add_firewalls: bool, add_images: bool, add_linodes: bool, add_longview: bool, add_nodebalancers: bool, add_stackscripts: bool, add_volumes: bool, cancel_account: bool, longview_subscription: bool}, image: [map], linode: [map], longview: [map], nodebalancer: [map], stackscript: [map], volume: [map]}
