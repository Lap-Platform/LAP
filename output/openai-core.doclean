@doclean v0.2
# Machine-readable API spec. Each @endpoint block is one API call.
@api OpenAI API
@base https://api.openai.com/v1
@version 2.0.0
@auth Bearer bearer
@endpoints 5
@toc Create chat completion, Create embeddings, List models, Retrieve model, Create image

@endpoint POST /chat/completions
@desc Create chat completion
@required {model: str # ID of the model to use (e.g. gpt-4o, gpt-4o-mini), messages: [map] # A list of messages comprising the conversation so far}
@optional {temperature: num=1 # Sampling temperature between 0 and 2. Higher values make output more random., top_p: num=1 # Nucleus sampling parameter. We generally recommend altering this or temperature but not both., n: int=1 # How many chat completion choices to generate for each input message, stream: bool=false # If set, partial message deltas will be sent as server-sent events, max_tokens: int # The maximum number of tokens that can be generated in the chat completion, stop: str # Up to 4 sequences where the API will stop generating further tokens, presence_penalty: num=0 # Number between -2.0 and 2.0. Positive values penalize new tokens based on whether they appear in the text so far., frequency_penalty: num=0 # Number between -2.0 and 2.0. Positive values penalize new tokens based on their existing frequency in the text so far., tools: [map] # A list of tools the model may call. Currently only functions are supported., tool_choice: str # Controls which (if any) tool is called by the model (auto, none, required, or object), response_format: map # An object specifying the format that the model must output (e.g. json_object, json_schema), seed: int # If specified, system will make a best effort to sample deterministically, user: str # A unique identifier representing your end-user for abuse monitoring}
@returns(200) {id: str, object: str, created: int, model: str, choices: [map], usage: map{prompt_tokens: int, completion_tokens: int, total_tokens: int}} # Chat completion response
@errors {401: Invalid authentication, 429: Rate limit reached, 500: Server error}

@endpoint POST /embeddings
@desc Create embeddings
@required {model: str # ID of the model to use (e.g. text-embedding-3-small, text-embedding-3-large), input: str # Input text to embed. Can be a string or array of strings.}
@optional {encoding_format: str(float/base64)=float # The format to return the embeddings in, dimensions: int # The number of dimensions the resulting output embeddings should have (only for v3 models), user: str # A unique identifier representing your end-user}
@returns(200) {object: str, data: [map], model: str, usage: map{prompt_tokens: int, total_tokens: int}} # Embedding response
@errors {401: Invalid authentication, 429: Rate limit reached}

@endpoint GET /models
@desc List models
@returns(200) {object: str, data: [map]} # List of models
@errors {401: Invalid authentication}

@endpoint GET /models/{model}
@desc Retrieve model
@required {model: str # The ID of the model to retrieve}
@returns(200) Model details
@errors {401: Invalid authentication, 404: Model not found}

@endpoint POST /images/generations
@desc Create image
@required {prompt: str # A text description of the desired image(s). Maximum 4000 characters.}
@optional {model: str=dall-e-2 # The model to use for image generation (dall-e-2 or dall-e-3), n: int=1 # The number of images to generate (1-10 for dall-e-2, only 1 for dall-e-3), size: str(256x256/512x512/1024x1024/1792x1024/1024x1792)=1024x1024 # The size of the generated images, quality: str(standard/hd)=standard # The quality of the image (only for dall-e-3), response_format: str(url/b64_json)=url # The format in which generated images are returned, style: str(vivid/natural)=vivid # The style of the generated images (only for dall-e-3), user: str # A unique identifier representing your end-user}
@returns(200) {created: int, data: [map]} # Image generation response
@errors {400: Invalid request, 401: Invalid authentication}

@end

