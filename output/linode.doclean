@desc Domain Create
@returns(200) {axfr_ips: [str(ip)], description: str, domain: str, expire_sec: int, group: str, id: int, master_ips: [str(ip)], refresh_sec: int, retry_sec: int, soa_email: str(email), status: str, tags: [str], ttl_sec: int, type: str} # Domain added successfully.


@endpoint POST /domains/import
@desc Domain Import
@required {domain: str # The domain to import., remote_nameserver: str # The remote nameserver that allows zone transfers (AXFR).}
@returns(200) {axfr_ips: [str(ip)], description: str, domain: str, expire_sec: int, group: str, id: int, master_ips: [str(ip)], refresh_sec: int, retry_sec: int, soa_email: str(email), status: str, tags: [str], ttl_sec: int, type: str} # A single Domain in Linode's DNS Manager.


@endpoint DELETE /domains/{domainId}
@desc Domain Delete
@returns(200) Domain deleted successfully.

@endpoint GET /domains/{domainId}
@desc Domain View
@returns(200) {axfr_ips: [str(ip)], description: str, domain: str, expire_sec: int, group: str, id: int, master_ips: [str(ip)], refresh_sec: int, retry_sec: int, soa_email: str(email), status: str, tags: [str], ttl_sec: int, type: str} # A single Domain in Linode's DNS Manager.


@endpoint PUT /domains/{domainId}
@desc Domain Update
@optional {axfr_ips: [str(ip)] # The list of IPs that may perform a zone transfer for this Domain. The total combined length of all data within this array cannot exceed 1000 characters.  **Note**: This is potentially dangerous, and should be set to an empty list unless you intend to use it., description: str # A description for this Domain. This is for display purposes only., domain: str # The domain this Domain represents. Domain labels cannot be longer than 63 characters and must conform to [RFC1035](https://tools.ietf.org/html/rfc1035). Domains must be unique on Linode's platform, including across different Linode accounts; there cannot be two Domains representing the same domain., expire_sec: int=0 # The amount of time in seconds that may pass before this Domain is no longer authoritative.  * Valid values are 0, 300, 3600, 7200, 14400, 28800, 57600, 86400, 172800, 345600, 604800, 1209600, and 2419200.  * Any other value is rounded up to the nearest valid value.  * A value of 0 is equivalent to the default value of 1209600., group: str # The group this Domain belongs to.  This is for display purposes only., id: int # This Domain's unique ID, master_ips: [str(ip)] # The IP addresses representing the master DNS for this Domain. At least one value is required for `type` slave Domains. The total combined length of all data within this array cannot exceed 1000 characters., refresh_sec: int=0 # The amount of time in seconds before this Domain should be refreshed.  * Valid values are 0, 300, 3600, 7200, 14400, 28800, 57600, 86400, 172800, 345600, 604800, 1209600, and 2419200.  * Any other value is rounded up to the nearest valid value.  * A value of 0 is equivalent to the default value of 14400., retry_sec: int=0 # The interval, in seconds, at which a failed refresh should be retried.  * Valid values are 0, 300, 3600, 7200, 14400, 28800, 57600, 86400, 172800, 345600, 604800, 1209600, and 2419200.  * Any other value is rounded up to the nearest valid value.  * A value of 0 is equivalent to the default value of 14400., soa_email: str(email) # Start of Authority email address. This is required for `type` master Domains., status: str(disabled/active)=active # Used to control whether this Domain is currently being rendered., tags: [str] # An array of tags applied to this object.  Tags are for organizational purposes only., ttl_sec: int=0 # "Time to Live" - the amount of time in seconds that this Domain's records may be cached by resolvers or other domain servers. * Valid values are 0, 300, 3600, 7200, 14400, 28800, 57600, 86400, 172800, 345600, 604800, 1209600, and 2419200. * Any other value is rounded up to the nearest valid value. * A value of 0 is equivalent to the default value of 86400., type: str(master/slave) # Whether this Domain represents the authoritative source of information for the domain it describes ("master"), or whether it is a read-only copy of a master ("slave").}
@returns(200) {axfr_ips: [str(ip)], description: str, domain: str, expire_sec: int, group: str, id: int, master_ips: [str(ip)], refresh_sec: int, retry_sec: int, soa_email: str(email), status: str, tags: [str], ttl_sec: int, type: str} # Domain update successful.

@endpoint POST /domains/{domainId}/clone
@desc Domain Clone
@required {domain: str # The new domain for the clone. Domain labels cannot be longer than 63 characters and must conform to [RFC1035](https://tools.ietf.org/html/rfc1035). Domains must be unique on Linode's platform, including across different Linode accounts; there cannot be two Domains representing the same domain.}
@returns(200) {axfr_ips: [str(ip)], description: str, domain: str, expire_sec: int, group: str, id: int, master_ips: [str(ip)], refresh_sec: int, retry_sec: int, soa_email: str(email), status: str, tags: [str], ttl_sec: int, type: str} # A new Domain in Linode's DNS Manager, based on a cloned Domain.


