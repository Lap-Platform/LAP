@endpoint PUT /domains/{domainId}/records/{recordId}
@desc Domain Record Update
@optional {name: str # The name of this Record. For requests, this property's actual usage and whether it is required depends on the type of record this represents:  `A` and `AAAA`: The hostname or FQDN of the Record.  `NS`: The subdomain, if any, to use with the Domain of the Record. Wildcard NS records (`*`) are not supported.  `MX`: The mail subdomain. For example, `sub` for the address `user@sub.example.com` under the `example.com` Domain. Must be an empty string (`""`) for a Null MX Record.  `CNAME`: The hostname. Must be unique. Required.  `TXT`: The hostname.  `SRV`: Unused. Use the `service` property to set the service name for this record.  `CAA`: The subdomain. Omit or enter an empty string (`""`) to apply to the entire Domain.  `PTR`: See our guide on how to [Configure Your Linode for Reverse DNS (rDNS)](/docs/guides/configure-rdns/)., port: int # The port this Record points to. Only valid and required for SRV record requests., priority: int # The priority of the target host for this Record. Lower values are preferred. Only valid for MX and SRV record requests. Required for SRV record requests.  Defaults to `0` for MX record requests. Must be `0` for Null MX records., protocol: str # The protocol this Record's service communicates with. An underscore (`_`) is prepended automatically to the submitted value for this property. Only valid for SRV record requests., service: str # The name of the service. An underscore (`_`) is prepended and a period (`.`) is appended automatically to the submitted value for this property. Only valid and required for SRV record requests., tag: str(issue/issuewild/iodef) # The tag portion of a CAA record. Only valid and required for CAA record requests., target: str # The target for this Record. For requests, this property's actual usage and whether it is required depends on the type of record this represents:  `A` and `AAAA`: The IP address. Use `[remote_addr]` to submit the IPv4 address of the request. Required.  `NS`: The name server. Must be a valid domain. Required.  `MX`: The mail server. Must be a valid domain unless creating a Null MX Record. To create a [Null MX Record](https://datatracker.ietf.org/doc/html/rfc7505), first [remove](/docs/api/domains/#domain-record-delete) any additional MX records, create an MX record with empty strings (`""`) for the `target` and `name`. If a Domain has a Null MX record, new MX records cannot be created. Required.  `CNAME`: The alias. Must be a valid domain. Required.  `TXT`: The value. Required.  `SRV`: The target domain or subdomain. If a subdomain is entered, it is automatically used with the Domain. To configure for a different domain, enter a valid FQDN. For example, the value `www` with a Domain for `example.com` results in a target set to `www.example.com`, whereas the value `sample.com` results in a target set to `sample.com`. Required.  `CAA`: The value. For `issue` or `issuewild` tags, the domain of your certificate issuer. For the `iodef` tag, a contact or submission URL (domain, http, https, or mailto). Requirements depend on the tag for this record:   * `issue`: The domain of your certificate issuer. Must be a valid domain.   * `issuewild`: Must begin with `*`.   * `iodef`: Must be either (1) a valid domain, (2) a valid domain prepended with `http://` or `https://`, or (3) a valid email address prepended with `mailto:`.  `PTR`: Required. See our guide on how to [Configure Your Linode for Reverse DNS (rDNS)](/docs/guides/configure-rdns/).  With the exception of A, AAAA, and CAA records, this field accepts a trailing period., ttl_sec: int # "Time to Live" - the amount of time in seconds that this Domain's records may be cached by resolvers or other domain servers. Valid values are 300, 3600, 7200, 14400, 28800, 57600, 86400, 172800, 345600, 604800, 1209600, and 2419200 - any other value will be rounded to the nearest valid value., weight: int # The relative weight of this Record used in the case of identical priority. Higher values are preferred. Only valid and required for SRV record requests.}
@returns(200) {created: str(date-time), id: int, name: str, port: int, priority: int, protocol: str?, service: str?, tag: str?, target: str, ttl_sec: int, type: str, updated: str(date-time), weight: int} # Domain Record updated.

@endpoint GET /domains/{domainId}/zone-file
@desc Domain Zone File View
@returns(200) {zone_file: [str]} # An array containing the lines of the domain zone file.


@endpoint GET /images
@desc Images List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # A paginated list of Images.

@endpoint POST /images
@desc Image Create
@required {disk_id: int # The ID of the Linode Disk that this Image will be created from.}
@optional {description: str # A detailed description of this Image., label: str # A short title of this Image. Defaults to the label of the Disk it is being created from if not provided.}
@returns(200) {created: str(date-time), created_by: str, deprecated: bool, description: str?, eol: str(date-time), expiry: str(date-time)?, id: str, is_public: bool, label: str, size: int, status: str, type: str, updated: str(date-time), vendor: str} # New private Image created successfully.

@endpoint POST /images/upload
@desc Image Upload
@required {label: str # Label for the uploaded Image., region: str # The region to upload to. Once uploaded, the Image can be used in any region.}
@optional {description: str # Description for the uploaded Image.}
@returns(200) {image: map{created: str(date-time), created_by: str, deprecated: bool, description: str?, eol: str(date-time), expiry: str(date-time)?, id: str, is_public: bool, label: str, size: int, status: str, type: str, updated: str(date-time), vendor: str}, upload_to: str} # Image Upload object including the upload URL and Image object.

@endpoint DELETE /images/{imageId}
@desc Image Delete
@returns(200) Delete successful

@endpoint GET /images/{imageId}
@desc Image View
@returns(200) {created: str(date-time), created_by: str, deprecated: bool, description: str?, eol: str(date-time), expiry: str(date-time)?, id: str, is_public: bool, label: str, size: int, status: str, type: str, updated: str(date-time), vendor: str} # A single Image object.

@endpoint PUT /images/{imageId}
@desc Image Update
@optional {created: str(date-time) # When this Image was created., created_by: str # The name of the User who created this Image, or "linode" for public Images., deprecated: bool # Whether or not this Image is deprecated. Will only be true for deprecated public Images., description: str # A detailed description of this Image., eol: str(date-time) # The date of the public Image's planned end of life. `None` for private Images., expiry: str(date-time) # Only Images created automatically from a deleted Linode (type=automatic) will expire., id: str # The unique ID of this Image., is_public: bool # True if the Image is a public distribution image. False if Image is private Account-specific Image., label: str # A short description of the Image., size: int # The minimum size this Image needs to deploy. Size is in MB., status: str(creating/pending_upload/available) # The current status of this Image.  Only Images in an "available" status can be deployed. Images in a "creating" status are being created from a Linode Disk, and will become "available" shortly. Images in a "pending_upload" status are waiting for data to be [uploaded](/docs/api/images/#image-upload), and become "available" after the upload and processing are complete.  The "+order_by" and "+order" operators are not available for [filtering](/docs/api/#filtering-and-sorting) on this key., type: str(manual/automatic) # How the Image was created.  "Manual" Images can be created at any time.  "Automatic" Images are created automatically from a deleted Linode., updated: str(date-time) # When this Image was last updated., vendor: str # The upstream distribution vendor. `None` for private Images.}
@returns(200) {created: str(date-time), created_by: str, deprecated: bool, description: str?, eol: str(date-time), expiry: str(date-time)?, id: str, is_public: bool, label: str, size: int, status: str, type: str, updated: str(date-time), vendor: str} # The updated image.

@endpoint GET /linode/instances
@desc Linodes List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns an array of all Linodes on your Account.

@endpoint POST /linode/instances
@desc Linode Create
@returns(200) {alerts: map{cpu: int, io: int, network_in: int, network_out: int, transfer_quota: int}, backups: map{available: bool, enabled: bool, last_successful: str(date-time), schedule: map{day: str?, window: str?}}, created: str(date-time), group: str, host_uuid: str(uuid), hypervisor: str, id: int, image: any?, ipv4: [str], ipv6: str(ipv6/128)?, label: str, region: str, specs: map{disk: int, memory: int, transfer: int, vcpus: int}, status: str, tags: [str], type: str, updated: str(date-time), watchdog_enabled: bool} # A new Linode is being created.


@endpoint DELETE /linode/instances/{linodeId}
@desc Linode Delete
@returns(200) Delete successful

@endpoint GET /linode/instances/{linodeId}
@desc Linode View
@returns(200) {alerts: map{cpu: int, io: int, network_in: int, network_out: int, transfer_quota: int}, backups: map{available: bool, enabled: bool, last_successful: str(date-time), schedule: map{day: str?, window: str?}}, created: str(date-time), group: str, host_uuid: str(uuid), hypervisor: str, id: int, image: any?, ipv4: [str], ipv6: str(ipv6/128)?, label: str, region: str, specs: map{disk: int, memory: int, transfer: int, vcpus: int}, status: str, tags: [str], type: str, updated: str(date-time), watchdog_enabled: bool} # Returns a single Linode object.

@endpoint PUT /linode/instances/{linodeId}
@desc Linode Update
@optional {alerts: map, backups: map # Information about this Linode's backups status. For information about available backups, see [/linode/instances/{linodeId}/backups](/docs/api/linode-instances/#backups-list)., created: str(date-time) # When this Linode was created., group: str # A deprecated property denoting a group label for this Linode., host_uuid: str(uuid) # The Linode's host machine, as a UUID., hypervisor: str # The virtualization software powering this Linode., id: int # This Linode's ID which must be provided for all operations impacting this Linode., image: any, ipv4: [str] # This Linode's IPv4 Addresses. Each Linode is assigned a single public IPv4 address upon creation, and may get a single private IPv4 address if needed. You may need to [open a support ticket](/docs/api/support/#support-ticket-open) to get additional IPv4 addresses.  IPv4 addresses may be reassigned between your Linodes, or shared with other Linodes. See the [/networking](/docs/api/networking/) endpoints for details., ipv6: str(ipv6/128) # This Linode's IPv6 SLAAC address. This address is specific to a Linode, and may not be shared. If the Linode has not been assigned an IPv6 address, the return value will be `null`., label: str # The Linode's label is for display purposes only. If no label is provided for a Linode, a default will be assigned.  Linode labels have the following constraints:    * Must begin and end with an alphanumeric character.   * May only consist of alphanumeric characters, dashes (`-`), underscores (`_`) or periods (`.`).   * Cannot have two dashes (`--`), underscores (`__`) or periods (`..`) in a row., region: str # This is the [Region](/docs/api/regions/#regions-list) where the Linode was deployed. A Linode's region can only be changed by initiating a [cross data center migration](/docs/api/linode-instances/#dc-migrationpending-host-migration-initiate)., specs: map # Information about the resources available to this Linode., status: str(running/offline/booting/rebooting/shutting_down/provisioning/deleting/migrating/rebuilding/cloning/restoring/stopped) # A brief description of this Linode's current state. This field may change without direct action from you. For example, when a Linode goes into maintenance mode its status will display "stopped"., tags: [str] # An array of tags applied to this object.  Tags are for organizational purposes only., type: str # This is the [Linode Type](/docs/api/linode-types/#types-list) that this Linode was deployed with. To change a Linode's Type, use [POST /linode/instances/{linodeId}/resize](/docs/api/linode-instances/#linode-resize)., updated: str(date-time) # When this Linode was last updated., watchdog_enabled: bool # The watchdog, named Lassie, is a Shutdown Watchdog that monitors your Linode and will reboot it if it powers off unexpectedly. It works by issuing a boot job when your Linode powers off without a shutdown job being responsible. To prevent a loop, Lassie will give up if there have been more than 5 boot jobs issued within 15 minutes.}
@returns(200) {alerts: map{cpu: int, io: int, network_in: int, network_out: int, transfer_quota: int}, backups: map{available: bool, enabled: bool, last_successful: str(date-time), schedule: map{day: str?, window: str?}}, created: str(date-time), group: str, host_uuid: str(uuid), hypervisor: str, id: int, image: any?, ipv4: [str], ipv6: str(ipv6/128)?, label: str, region: str, specs: map{disk: int, memory: int, transfer: int, vcpus: int}, status: str, tags: [str], type: str, updated: str(date-time), watchdog_enabled: bool} # The updated Linode.

@endpoint GET /linode/instances/{linodeId}/backups
@desc Backups List
@returns(200) {automatic: [any], snapshot: map{current: map{available: bool, configs: [str], created: str(date-time), disks: [map], finished: str(date-time), id: int, label: str?, status: str, type: str, updated: str(date-time)}, in_progress: map{available: bool, configs: [str], created: str(date-time), disks: [map], finished: str(date-time), id: int, label: str?, status: str, type: str, updated: str(date-time)}}} # A collection of the specified Linode's available backups.

@endpoint POST /linode/instances/{linodeId}/backups
@desc Snapshot Create
@required {label: str # The label for the new snapshot.}
@returns(200) {available: bool, configs: [str], created: str(date-time), disks: [map], finished: str(date-time), id: int, label: str?, status: str, type: str, updated: str(date-time)} # Snapshot request successful.

@endpoint POST /linode/instances/{linodeId}/backups/cancel
@desc Backups Cancel
@returns(200) Backup service was cancelled for the specified Linode.

@endpoint POST /linode/instances/{linodeId}/backups/enable
@desc Backups Enable
@returns(200) Backup service was enabled.

@endpoint GET /linode/instances/{linodeId}/backups/{backupId}
@desc Backup View
@returns(200) {available: bool, configs: [str], created: str(date-time), disks: [map], finished: str(date-time), id: int, label: str?, status: str, type: str, updated: str(date-time)} # A single Backup.

@endpoint POST /linode/instances/{linodeId}/backups/{backupId}/restore
@desc Backup Restore
@required {linode_id: int # The ID of the Linode to restore a Backup to.}
@optional {overwrite: bool # If True, deletes all Disks and Configs on the target Linode before restoring.  If False, and the Disk image size is larger than the available space on the Linode, an error message indicating insufficient space is returned.}
@returns(200) Restore from Backup was initiated.

@endpoint POST /linode/instances/{linodeId}/boot
@desc Linode Boot
@optional {config_id: int # The Linode Config ID to boot into.}
@returns(200) Boot started.

@endpoint POST /linode/instances/{linodeId}/clone
@desc Linode Clone
@optional {backups_enabled: bool # If this field is set to `true`, the created Linode will automatically be enrolled in the Linode Backup service. This will incur an additional charge. Pricing is included in the response from [/linodes/types](/docs/api/linode-types/#types-list).  * Can only be included when cloning to a new Linode., configs: [int] # An array of configuration profile IDs. * If the `configs` parameter **is not provided**, then **all configuration profiles and their associated disks will be cloned** from the source Linode. Any disks specified by the `disks` parameter will also be cloned. * **If an empty array is provided** for the `configs` parameter, then **no configuration profiles (nor their associated disks) will be cloned** from the source Linode. Any disks specified by the `disks` parameter will still be cloned. * **If a non-empty array is provided** for the `configs` parameter, then **the configuration profiles specified in the array (and their associated disks) will be cloned** from the source Linode. Any disks specified by the `disks` parameter will also be cloned., disks: [int] # An array of disk IDs. * If the `disks` parameter **is not provided**, then **no extra disks will be cloned** from the source Linode. All disks associated with the configuration profiles specified by the `configs` parameter will still be cloned. * **If an empty array is provided** for the `disks` parameter, then **no extra disks will be cloned** from the source Linode. All disks associated with the configuration profiles specified by the `configs` parameter will still be cloned. * **If a non-empty array is provided** for the `disks` parameter, then **the disks specified in the array will be cloned** from the source Linode, in addition to any disks associated with the configuration profiles specified by the `configs` parameter., group: str # A label used to group Linodes for display. Linodes are not required to have a group., label: str # The label to assign this Linode when cloning to a new Linode. * Can only be provided when cloning to a new Linode. * Defaults to "linode"., linode_id: int # If an existing Linode is the target for the clone, the ID of that Linode. The existing Linode must have enough resources to accept the clone., private_ip: bool # If true, the created Linode will have private networking enabled and assigned a private IPv4 address. * Can only be provided when cloning to a new Linode., region: str # This is the Region where the Linode will be deployed. To view all available Regions you can deploy to see [/regions](/docs/api/regions/#regions-list). * Region can only be provided and is required when cloning to a new Linode., type: str # A Linode's Type determines what resources are available to it, including disk space, memory, and virtual cpus. The amounts available to a specific Linode are returned as `specs` on the Linode object.  To view all available Linode Types you can deploy with see [/linode/types](/docs/api/linode-types/#types-list).  * Type can only be provided and is required when cloning to a new Linode.}
@returns(200) {alerts: map{cpu: int, io: int, network_in: int, network_out: int, transfer_quota: int}, backups: map{available: bool, enabled: bool, last_successful: str(date-time), schedule: map{day: str?, window: str?}}, created: str(date-time), group: str, host_uuid: str(uuid), hypervisor: str, id: int, image: any?, ipv4: [str], ipv6: str(ipv6/128)?, label: str, region: str, specs: map{disk: int, memory: int, transfer: int, vcpus: int}, status: str, tags: [str], type: str, updated: str(date-time), watchdog_enabled: bool} # Clone started.

@endpoint GET /linode/instances/{linodeId}/configs
@desc Configuration Profiles List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns an array of Configuration profiles associated with this Linode.


@endpoint POST /linode/instances/{linodeId}/configs
@desc Configuration Profile Create
@returns(200) {comments: str?, devices: map{sda: map{disk_id: int, volume_id: int}, sdb: map{disk_id: int, volume_id: int}, sdc: map{disk_id: int, volume_id: int}, sdd: map{disk_id: int, volume_id: int}, sde: map{disk_id: int, volume_id: int}, sdf: map{disk_id: int, volume_id: int}, sdg: map{disk_id: int, volume_id: int}, sdh: map{disk_id: int, volume_id: int}}, helpers: map{devtmpfs_automount: bool, distro: bool, modules_dep: bool, network: bool, updatedb_disabled: bool}, id: int, interfaces: [map], kernel: str, label: str, memory_limit: int, root_device: str, run_level: str, virt_mode: str} # A Configuration profile was created.


@endpoint DELETE /linode/instances/{linodeId}/configs/{configId}
@desc Configuration Profile Delete
@returns(200) Configuration profile successfully deleted.


@endpoint GET /linode/instances/{linodeId}/configs/{configId}
@desc Configuration Profile View
@returns(200) {comments: str?, devices: map{sda: map{disk_id: int, volume_id: int}, sdb: map{disk_id: int, volume_id: int}, sdc: map{disk_id: int, volume_id: int}, sdd: map{disk_id: int, volume_id: int}, sde: map{disk_id: int, volume_id: int}, sdf: map{disk_id: int, volume_id: int}, sdg: map{disk_id: int, volume_id: int}, sdh: map{disk_id: int, volume_id: int}}, helpers: map{devtmpfs_automount: bool, distro: bool, modules_dep: bool, network: bool, updatedb_disabled: bool}, id: int, interfaces: [map], kernel: str, label: str, memory_limit: int, root_device: str, run_level: str, virt_mode: str} # A Configuration profile object.

@endpoint PUT /linode/instances/{linodeId}/configs/{configId}
@desc Configuration Profile Update
@optional {comments: str # Optional field for arbitrary User comments on this Config., devices: map # A dictionary of device disks to use as a device map in a Linode's configuration profile. * An empty device disk dictionary or a dictionary with empty values for device slots is allowed. * If no devices are specified, booting from this configuration will hold until a device exists that allows the boot process to start., helpers: map # Helpers enabled when booting to this Linode Config., id: int # The ID of this Config., interfaces: [map] # An array of Network Interfaces to add to this Linode's Configuration Profile.  Up to three interface objects can be entered in this array. The position in the array determines the interface to which the settings apply:  - First/0:  eth0 - Second/1: eth1 - Third/2:  eth2  When updating a Linode's interfaces, *each interface must be redefined*. An empty interfaces array results in a default public interface configuration only.  If no public interface is configured, public IP addresses are still assigned to the Linode but will not be usable without manual configuration.  **Note:** Changes to Linode interface configurations can be enabled by rebooting the Linode.  **Note:** Only Next Generation Network (NGN) data centers support VLANs. Use the Regions ([/regions](/docs/api/regions/)) endpoint to view the capabilities of data center regions. If a VLAN is attached to your Linode and you attempt to migrate or clone it to a non-NGN data center, the migration or cloning will not initiate. If a Linode cannot be migrated because of an incompatibility, you will be prompted to select a different data center or contact support.  **Note:** See the [VLANs Overview](/docs/products/networking/vlans/#technical-specifications) guide to view additional specifications and limitations., kernel: str # A Kernel ID to boot a Linode with. Defaults to "linode/latest-64bit"., label: str # The Config's label is for display purposes only., memory_limit: int # Defaults to the total RAM of the Linode., root_device: str # The root device to boot. * If no value or an invalid value is provided, root device will default to `/dev/sda`. * If the device specified at the root device location is not mounted, the Linode will not boot until a device is mounted., run_level: str(default/single/binbash) # Defines the state of your Linode after booting. Defaults to `default`., virt_mode: str(paravirt/fullvirt) # Controls the virtualization mode. Defaults to `paravirt`. * `paravirt` is suitable for most cases. Linodes running in paravirt mode   share some qualities with the host, ultimately making it run faster since   there is less transition between it and the host. * `fullvirt` affords more customization, but is slower because 100% of the VM   is virtualized.}
@returns(200) {comments: str?, devices: map{sda: map{disk_id: int, volume_id: int}, sdb: map{disk_id: int, volume_id: int}, sdc: map{disk_id: int, volume_id: int}, sdd: map{disk_id: int, volume_id: int}, sde: map{disk_id: int, volume_id: int}, sdf: map{disk_id: int, volume_id: int}, sdg: map{disk_id: int, volume_id: int}, sdh: map{disk_id: int, volume_id: int}}, helpers: map{devtmpfs_automount: bool, distro: bool, modules_dep: bool, network: bool, updatedb_disabled: bool}, id: int, interfaces: [map], kernel: str, label: str, memory_limit: int, root_device: str, run_level: str, virt_mode: str} # Configuration profile successfully updated.

@endpoint GET /linode/instances/{linodeId}/disks
@desc Disks List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns a paginated list of disks associated with this Linode.

@endpoint POST /linode/instances/{linodeId}/disks
@desc Disk Create
@returns(200) {created: str(date-time), filesystem: str, id: int, label: str, size: int, status: str, updated: str(date-time)} # Disk created.

@endpoint DELETE /linode/instances/{linodeId}/disks/{diskId}
@desc Disk Delete
@returns(200) Delete successful

@endpoint GET /linode/instances/{linodeId}/disks/{diskId}
@desc Disk View
@returns(200) {created: str(date-time), filesystem: str, id: int, label: str, size: int, status: str, updated: str(date-time)} # Returns a single Disk object.

@endpoint PUT /linode/instances/{linodeId}/disks/{diskId}
@desc Disk Update
@optional {created: str(date-time) # When this Disk was created., filesystem: str(raw/swap/ext3/ext4/initrd) # The Disk filesystem can be one of:    * raw - No filesystem, just a raw binary stream.   * swap - Linux swap area.   * ext3 - The ext3 journaling filesystem for Linux.   * ext4 - The ext4 journaling filesystem for Linux.   * initrd - initrd (uncompressed initrd, ext2, max 32 MB)., id: int # This Disk's ID which must be provided for all operations impacting this Disk., label: str # The Disk's label is for display purposes only., size: int # The size of the Disk in MB., status: str(ready/not ready/deleting) # A brief description of this Disk's current state. This field may change without direct action from you, as a result of operations performed to the Disk or the Linode containing the Disk., updated: str(date-time) # When this Disk was last updated.}
@returns(200) {created: str(date-time), filesystem: str, id: int, label: str, size: int, status: str, updated: str(date-time)} # The updated Disk.

@endpoint POST /linode/instances/{linodeId}/disks/{diskId}/clone
@desc Disk Clone
@returns(200) {created: str(date-time), filesystem: str, id: int, label: str, size: int, status: str, updated: str(date-time)} # Disk clone initiated.

@endpoint POST /linode/instances/{linodeId}/disks/{diskId}/password
@desc Disk Root Password Reset
@required {password: str # The new root password for the OS installed on this Disk. The password must meet the complexity strength validation requirements for a strong password.}
@returns(200) Returns a single Disk object.

@endpoint POST /linode/instances/{linodeId}/disks/{diskId}/resize
@desc Disk Resize
@required {size: int # The desired size, in MB, of the disk.}
@returns(200) Resize started.

@endpoint GET /linode/instances/{linodeId}/firewalls
@desc Firewalls List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns a paginated list of Firewalls associated with this Linode.

@endpoint GET /linode/instances/{linodeId}/ips
@desc Networking Information List
@returns(200) {ipv4: map{private: [map], public: [map], reserved: [map], shared: [map]}, ipv6: map{global: map{prefix: int, range: str, region: str, route_target: str?}, link_local: map{address: str(ip), gateway: str, linode_id: int, prefix: int, public: bool, rdns: str, region: str, subnet_mask: str(ip), type: str}, slaac: map{address: str(ip), gateway: str, linode_id: int, prefix: int, public: bool, rdns: str, region: str, subnet_mask: str(ip), type: str}}} # Requested Linode's networking configuration.

@endpoint POST /linode/instances/{linodeId}/ips
@desc IPv4 Address Allocate
@required {public: bool # Whether to create a public or private IPv4 address., type: str # The type of address you are allocating. Only IPv4 addresses may be allocated through this endpoint.}
@returns(200) {address: str(ip), gateway: str(ip)?, linode_id: int, prefix: int, public: bool, rdns: str?, region: str, subnet_mask: str(ip), type: str} # IP address was successfully allocated.

@endpoint DELETE /linode/instances/{linodeId}/ips/{address}
@desc IPv4 Address Delete
@returns(200) IP address successfully removed.

@endpoint GET /linode/instances/{linodeId}/ips/{address}
@desc IP Address View
@returns(200) {address: str(ip), gateway: str(ip)?, linode_id: int, prefix: int, public: bool, rdns: str?, region: str, subnet_mask: str(ip), type: str} # A single IP address.

@endpoint PUT /linode/instances/{linodeId}/ips/{address}
@desc IP Address Update
@required {rdns: str # The reverse DNS assigned to this address. For public IPv4 addresses, this will be set to a default value provided by Linode if not explicitly set.}
@returns(200) {address: str(ip), gateway: str(ip)?, linode_id: int, prefix: int, public: bool, rdns: str?, region: str, subnet_mask: str(ip), type: str} # The updated IP address record.

@endpoint POST /linode/instances/{linodeId}/migrate
@desc DC Migration/Pending Host Migration Initiate
@optional {region: str # The region to which the Linode will be migrated. Must be a valid region slug. A list of regions can be viewed by using the [GET /regions](/docs/api/regions/#regions-list) endpoint. A cross data center migration will cancel a pending migration that has not yet been initiated. A cross data center migration will initiate a `linode_migrate_datacenter_create` event., upgrade: bool=False # When initiating a cross DC migration, setting this value to true will also ensure that the Linode is upgraded to the latest generation of hardware that corresponds to your Linode's Type, if any free upgrades are available for it. If no free upgrades are available, and this value is set to true, then the endpoint will return a 400 error code and the migration will not be performed. If the data center set in the `region` field does not allow upgrades, then the endpoint will return a 400 error code and the migration will not be performed.}
@returns(200) Scheduled migration started

@endpoint POST /linode/instances/{linodeId}/mutate
@desc Linode Upgrade
@optional {allow_auto_disk_resize: bool=True # Automatically resize disks when resizing a Linode. When resizing down to a smaller plan your Linode's data must fit within the smaller disk size.}
@returns(200) Mutate started.

@endpoint GET /linode/instances/{linodeId}/nodebalancers
@desc Linode NodeBalancers View
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns a paginated list of NodeBalancers.

@endpoint POST /linode/instances/{linodeId}/password
@desc Linode Root Password Reset
@required {root_pass: str # The root user's password on this Linode. Linode passwords must meet a password strength score requirement that is calculated internally by the API. If the strength requirement is not met, you will receive a Password does not meet strength requirement error.}
@returns(200) Password Reset.

@endpoint POST /linode/instances/{linodeId}/reboot
@desc Linode Reboot
@optional {config_id: int # The Linode Config ID to reboot into.  If null or omitted, the last booted config will be used.  If there was no last booted config and this Linode only has one config, it will be used.  If a config cannot be determined, an error will be returned.}
@returns(200) Reboot started.

@endpoint POST /linode/instances/{linodeId}/rebuild
@desc Linode Rebuild
@returns(200) {alerts: map{cpu: int, io: int, network_in: int, network_out: int, transfer_quota: int}, backups: map{available: bool, enabled: bool, last_successful: str(date-time), schedule: map{day: str?, window: str?}}, created: str(date-time), group: str, host_uuid: str(uuid), hypervisor: str, id: int, image: any?, ipv4: [str], ipv6: str(ipv6/128)?, label: str, region: str, specs: map{disk: int, memory: int, transfer: int, vcpus: int}, status: str, tags: [str], type: str, updated: str(date-time), watchdog_enabled: bool} # Rebuild started.

@endpoint POST /linode/instances/{linodeId}/rescue
@desc Linode Boot into Rescue Mode
@optional {devices: map}
@returns(200) Rescue started.

@endpoint POST /linode/instances/{linodeId}/resize
@desc Linode Resize
@required {type: str # The ID representing the Linode Type.}
@optional {allow_auto_disk_resize: bool=True # Automatically resize disks when resizing a Linode. When resizing down to a smaller plan your Linode's data must fit within the smaller disk size.}
@returns(200) Resize started.

@endpoint POST /linode/instances/{linodeId}/shutdown
@desc Linode Shut Down
@returns(200) Shutdown started.

