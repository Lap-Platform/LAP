@endpoint GET /lke/clusters
@desc Kubernetes Clusters List
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns an array of all Kubernetes clusters on your Account.

@endpoint POST /lke/clusters
@desc Kubernetes Cluster Create
@required {k8s_version: str # The desired Kubernetes version for this Kubernetes cluster in the format of &lt;major&gt;.&lt;minor&gt;, and the latest supported patch version will be deployed., label: str # This Kubernetes cluster's unique label for display purposes only. Labels have the following constraints:    * UTF-8 characters will be returned by the API using escape     sequences of their Unicode code points. For example, the     Japanese character *か* is 3 bytes in UTF-8 (`0xE382AB`). Its     Unicode code point is 2 bytes (`0x30AB`). APIv4 supports this     character and the API will return it as the escape sequence     using six 1 byte characters which represent 2 bytes of Unicode     code point (`"\u30ab"`).   * 4 byte UTF-8 characters are not supported.   * If the label is entirely composed of UTF-8 characters, the API     response will return the code points using up to 193 1 byte     characters., node_pools: [map], region: str # This Kubernetes cluster's location.}
@optional {control_plane: map # Defines settings for the Kubernetes Control Plane. Allows for the enabling of High Availability (HA) for Control Plane Components. Enabling High Availability for LKE is an **irreversible** change., tags: [str] # An array of tags applied to the Kubernetes cluster. Tags are for organizational purposes only.}
@returns(200) {control_plane: map{high_availability: bool}, created: str(date-time), id: int, k8s_version: str, label: str, region: str, tags: [str], updated: str(date-time)} # Kubernetes cluster creation has started.

@endpoint DELETE /lke/clusters/{clusterId}
@desc Kubernetes Cluster Delete
@returns(200) Delete successful

@endpoint GET /lke/clusters/{clusterId}
@desc Kubernetes Cluster View
@returns(200) {control_plane: map{high_availability: bool}, created: str(date-time), id: int, k8s_version: str, label: str, region: str, tags: [str], updated: str(date-time)} # Returns a single Kubernetes cluster.

@endpoint PUT /lke/clusters/{clusterId}
@desc Kubernetes Cluster Update
@optional {control_plane: map # Defines settings for the Kubernetes Control Plane. Allows for the enabling of High Availability (HA) for Control Plane Components.  Enabling High Availability for LKE is an **irreversible** change.  When upgrading pre-existing LKE clusters to use the HA Control Plane, the following changes will additionally occur:  - All nodes will be deleted and new nodes will be created to replace them.  - Any local storage (such as `hostPath` volumes) will be erased.  - The upgrade process may take several minutes to complete, as nodes will be replaced on a rolling basis., k8s_version: str # The desired Kubernetes version for this Kubernetes cluster in the format of &lt;major&gt;.&lt;minor&gt;. New and recycled Nodes in this cluster will be installed with the latest available patch for the Cluster's Kubernetes version.  When upgrading the Kubernetes version, only the next latest minor version following the current version can be deployed. For example, a cluster with Kubernetes version 1.19 can be upgraded to version 1.20, but not directly to 1.21.  The Kubernetes version of a cluster can not be downgraded., label: str # This Kubernetes cluster's unique label for display purposes only. Labels have the following constraints:    * UTF-8 characters will be returned by the API using escape     sequences of their Unicode code points. For example, the     Japanese character *か* is 3 bytes in UTF-8 (`0xE382AB`). Its     Unicode code point is 2 bytes (`0x30AB`). APIv4 supports this     character and the API will return it as the escape sequence     using six 1 byte characters which represent 2 bytes of Unicode     code point (`"\u30ab"`).   * 4 byte UTF-8 characters are not supported.   * If the label is entirely composed of UTF-8 characters, the API     response will return the code points using up to 193 1 byte     characters., tags: [str] # An array of tags applied to the Kubernetes cluster. Tags are for organizational purposes only. To delete a tag, exclude it from your `tags` array.}
@returns(200) {created: str(date-time), k8s_version: str, label: str, region: str, tags: [str], updated: str(date-time)} # Returns a single Kubernetes cluster.

@endpoint GET /lke/clusters/{clusterId}/api-endpoints
@desc Kubernetes API Endpoints List
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns the Kubernetes API server endpoints for this cluster.

@endpoint GET /lke/clusters/{clusterId}/dashboard
@desc Kubernetes Cluster Dashboard URL View
@returns(200) {url: str} # Returns a Kubernetes Cluster Dashboard URL.

@endpoint DELETE /lke/clusters/{clusterId}/kubeconfig
@desc Kubeconfig Delete
@returns(200) Kubeconfig file deleted and regenerated successfully.

@endpoint GET /lke/clusters/{clusterId}/kubeconfig
@desc Kubeconfig View
@returns(200) {kubeconfig: str} # Returns the Base64-encoded Kubeconfig file for this Kubernetes cluster.

@endpoint DELETE /lke/clusters/{clusterId}/nodes/{nodeId}
@desc Node Delete
@returns(200) Delete successful

@endpoint GET /lke/clusters/{clusterId}/nodes/{nodeId}
@desc Node View
@returns(200) {id: str, instance_id: int, status: str} # Returns the values of a node object in the form that it appears currently in the node pool array.

@endpoint POST /lke/clusters/{clusterId}/nodes/{nodeId}/recycle
@desc Node Recycle
@returns(200) Recycle request succeeded and is in progress.

@endpoint GET /lke/clusters/{clusterId}/pools
@desc Node Pools List
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns an array of all Pools in this Kubernetes cluster.

@endpoint POST /lke/clusters/{clusterId}/pools
@desc Node Pool Create
@returns(200) {autoscaler: map{enabled: bool, max: int, min: int}, count: int, disks: [map], id: int, nodes: [map], tags: [str], type: str} # Node Pool has been created.

@endpoint DELETE /lke/clusters/{clusterId}/pools/{poolId}
@desc Node Pool Delete
@returns(200) Delete successful

@endpoint GET /lke/clusters/{clusterId}/pools/{poolId}
@desc Node Pool View
@returns(200) {autoscaler: map{enabled: bool, max: int, min: int}, count: int, disks: [map], id: int, nodes: [map], tags: [str], type: str} # Returns the requested Node Pool.

@endpoint PUT /lke/clusters/{clusterId}/pools/{poolId}
@desc Node Pool Update
@optional {autoscaler: map # When enabled, the number of nodes autoscales within the defined minimum and maximum values.  When making a request, `max` and `min` require each other., count: int # The number of nodes in the Node Pool.}
@returns(200) {autoscaler: map{enabled: bool, max: int, min: int}, count: int, disks: [map], id: int, nodes: [map], tags: [str], type: str} # Node Pool was successfully modified.

@endpoint POST /lke/clusters/{clusterId}/pools/{poolId}/recycle
@desc Node Pool Recycle
@returns(200) Recycle request succeeded and is in progress.

@endpoint POST /lke/clusters/{clusterId}/recycle
@desc Cluster Nodes Recycle
@returns(200) Recycle request succeeded and is in progress.

@endpoint POST /lke/clusters/{clusterId}/regenerate
@desc Kubernetes Cluster Regenerate
@optional {kubeconfig: bool=False # Whether to delete and regenerate the Kubeconfig file for this Cluster., servicetoken: bool=False # Whether to delete and regenerate the service access token for this Cluster.}
@returns(200) Regenerate request successful.

