@desc Support Ticket View
@returns(200) {attachments: [str], closable: bool, closed: str(date-time)?, description: str, entity: map?{id: int, label: str, type: str, url: str}, gravatar_id: str, id: int, opened: str(date-time), opened_by: str, status: str, summary: str, updated: str(date-time), updated_by: str?} # Returns a single SupportTicket object.

@endpoint POST /support/tickets/{ticketId}/attachments
@desc Support Ticket Attachment Create
@returns(200) Attachment created.

@endpoint POST /support/tickets/{ticketId}/close
@desc Support Ticket Close
@returns(200) Support Ticket closed successfully.

@endpoint GET /support/tickets/{ticketId}/replies
@desc Replies List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns a paginated list of SupportTicketReply objects.

@endpoint POST /support/tickets/{ticketId}/replies
@desc Reply Create
@required {description: str # The content of your reply.}
@returns(200) {created: str(date-time), created_by: str, description: str, from_linode: bool, gravatar_id: str, id: int} # Reply created.

@endpoint GET /tags
@desc Tags List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # A paginated list of Tags

@endpoint POST /tags
@desc New Tag Create
@required {label: str # The new Tag.}
@optional {domains: [int] # A list of Domain IDs to apply the new Tag to.  You must be allowed to `read_write` all of the requested Domains, or the Tag will not be created and an error will be returned., linodes: [int] # A list of Linode IDs to apply the new Tag to.  You must be allowed to `read_write` all of the requested Linodes, or the Tag will not be created and an error will be returned., nodebalancers: [int] # A list of NodeBalancer IDs to apply the new Tag to. You must be allowed to `read_write` all of the requested NodeBalancers, or the Tag will not be created and an error will be returned., volumes: [int] # A list of Volume IDs to apply the new Tag to.  You must be allowed to `read_write` all of the requested Volumes, or the Tag will not be created and an error will be returned.}
@returns(200) {label: str} # The new Tag.

@endpoint DELETE /tags/{label}
@desc Tag Delete
@returns(200) Tag deleted.

@endpoint GET /tags/{label}
@desc Tagged Objects List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # A paginated list of objects, organized by type, that have been tagged with the requested Tag.


@endpoint GET /volumes
@desc Volumes List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # Returns an array of all Volumes on your Account.

@endpoint POST /volumes
@desc Volume Create
@required {label: str # The Volume's label, which is also used in the `filesystem_path` of the resulting volume.}
@optional {config_id: int # When creating a Volume attached to a Linode, the ID of the Linode Config to include the new Volume in. This Config must belong to the Linode referenced by `linode_id`. Must _not_ be provided if `linode_id` is not sent. If a `linode_id` is sent without a `config_id`, the volume will be attached:    * to the Linode's only config if it only has one config.   * to the Linode's last used config, if possible.  If no config can be selected for attachment, an error will be returned., linode_id: int # The Linode this volume should be attached to upon creation. If not given, the volume will be created without an attachment., region: str # The Region to deploy this Volume in. This is only required if a linode_id is not given., size: int=20 # The initial size of this volume, in GB.  Be aware that volumes may only be resized up after creation., tags: [str] # An array of Tags applied to this object.  Tags are for organizational purposes only.}
@returns(200) {created: str(date-time), filesystem_path: str, hardware_type: str, id: int, label: str, linode_id: int?, linode_label: str?, region: str, size: int, status: str, tags: [str], updated: str(date-time)} # Creating Volume.


@endpoint DELETE /volumes/{volumeId}
@desc Volume Delete
@returns(200) Volume deletion successful.

@endpoint GET /volumes/{volumeId}
@desc Volume View
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {created: str(date-time), filesystem_path: str, hardware_type: str, id: int, label: str, linode_id: int?, linode_label: str?, region: str, size: int, status: str, tags: [str], updated: str(date-time)} # Returns a single Volume object.

@endpoint PUT /volumes/{volumeId}
@desc Volume Update
@returns(200) {created: str(date-time), filesystem_path: str, hardware_type: str, id: int, label: str, linode_id: int?, linode_label: str?, region: str, size: int, status: str, tags: [str], updated: str(date-time)} # The updated Volume.

@endpoint POST /volumes/{volumeId}/attach
@desc Volume Attach
@required {linode_id: int # The ID of the Linode to attach the volume to.}
@optional {config_id: int # The ID of the Linode Config to include this Volume in. Must belong to the Linode referenced by `linode_id`. If not given, the last booted Config will be chosen., persist_across_boots: bool # Defaults to true, if false is provided, the Volume will not be attached to the Linode Config. In this case more than 8 Volumes may be attached to a Linode if a Linode has 16GB of RAM or more. The number of volumes that can be attached is equal to the number of GB of RAM that the Linode has, up to a maximum of 64. `config_id` should not be passed if this is set to false and linode_id must be passed. The Linode must be running.}
@returns(200) {created: str(date-time), filesystem_path: str, hardware_type: str, id: int, label: str, linode_id: int?, linode_label: str?, region: str, size: int, status: str, tags: [str], updated: str(date-time)} # Volume was attached to a Linode.

@endpoint POST /volumes/{volumeId}/clone
@desc Volume Clone
@required {label: str # The Volume's label is for display purposes only.}
@returns(200) {created: str(date-time), filesystem_path: str, hardware_type: str, id: int, label: str, linode_id: int?, linode_label: str?, region: str, size: int, status: str, tags: [str], updated: str(date-time)} # Clone started.

@endpoint POST /volumes/{volumeId}/detach
@desc Volume Detach
@returns(200) Volume was detached from a Linode.

@endpoint POST /volumes/{volumeId}/resize
@desc Volume Resize
@required {size: int # The Volume's size, in GiB.}
@returns(200) {created: str(date-time), filesystem_path: str, hardware_type: str, id: int, label: str, linode_id: int?, linode_label: str?, region: str, size: int, status: str, tags: [str], updated: str(date-time)} # Volume resize started.

@end

