@endpoint GET /linode/stackscripts
@desc StackScripts List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # A list of StackScripts available to the User, including private StackScripts owned by the User if the request is authenticated.


@endpoint POST /linode/stackscripts
@desc StackScript Create
@returns(200) {created: str(date-time), deployments_active: int, deployments_total: int, description: str, id: int, images: [str], is_public: bool, label: str, mine: bool, rev_note: str, script: str, updated: str(date-time), user_defined_fields: [map], user_gravatar_id: str, username: str} # StackScript successfully created.

@endpoint DELETE /linode/stackscripts/{stackscriptId}
@desc StackScript Delete
@returns(200) StackScript was deleted.

@endpoint GET /linode/stackscripts/{stackscriptId}
@desc StackScript View
@returns(200) {created: str(date-time), deployments_active: int, deployments_total: int, description: str, id: int, images: [str], is_public: bool, label: str, mine: bool, rev_note: str, script: str, updated: str(date-time), user_defined_fields: [map], user_gravatar_id: str, username: str} # A single StackScript.

@endpoint PUT /linode/stackscripts/{stackscriptId}
@desc StackScript Update
@optional {created: str(date-time) # The date this StackScript was created., deployments_active: int # Count of currently active, deployed Linodes created from this StackScript., deployments_total: int # The total number of times this StackScript has been deployed., description: str # A description for the StackScript., id: int # The unique ID of this StackScript., images: [str] # An array of Image IDs. These are the Images that can be deployed with this StackScript.  `any/all` indicates that all available Images, including private Images, are accepted., is_public: bool # This determines whether other users can use your StackScript. **Once a StackScript is made public, it cannot be made private.**, label: str # The StackScript's label is for display purposes only., mine: bool # Returns `true` if this StackScript is owned by the account of the user making the request, and the user making the request is unrestricted or has access to this StackScript., rev_note: str # This field allows you to add notes for the set of revisions made to this StackScript., script: str # The script to execute when provisioning a new Linode with this StackScript., updated: str(date-time) # The date this StackScript was last updated., user_defined_fields: [map] # This is a list of fields defined with a special syntax inside this StackScript that allow for supplying customized parameters during deployment. See [Declare User-Defined Fields (UDFs)](/docs/products/tools/stackscripts/guides/write-a-custom-script/#declare-user-defined-fields-udfs) for more information., user_gravatar_id: str # The Gravatar ID for the User who created the StackScript., username: str # The User who created the StackScript.}
@returns(200) {created: str(date-time), deployments_active: int, deployments_total: int, description: str, id: int, images: [str], is_public: bool, label: str, mine: bool, rev_note: str, script: str, updated: str(date-time), user_defined_fields: [map], user_gravatar_id: str, username: str} # StackScript was successfully modified.

