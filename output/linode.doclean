@desc Linode's Managed Settings Update
@optional {group: str # The group of the Linode these Settings are for. This is for display purposes only., id: int # The ID of the Linode these Settings are for., label: str # The label of the Linode these Settings are for., ssh: map # The SSH settings for this Linode.}
@returns(200) {group: str, id: int, label: str, ssh: map{access: bool, ip: str(ip), port: int?, user: str?}} # Settings updated successfully.

@endpoint GET /managed/services
@desc Managed Services List
@returns(200) {data: [map], page: int, pages: int, results: int} # A paginated list of Managed Services

@endpoint POST /managed/services
@desc Managed Service Create
@returns(200) {address: str(url), body: str?, consultation_group: str, created: str(date-time), credentials: [int], id: int, label: str, notes: str?, region: str, service_type: str, status: str, timeout: int, updated: str(date-time)} # Service created.

@endpoint DELETE /managed/services/{serviceId}
@desc Managed Service Delete
@returns(200) Service deleted successfully.

@endpoint GET /managed/services/{serviceId}
@desc Managed Service View
@returns(200) {address: str(url), body: str?, consultation_group: str, created: str(date-time), credentials: [int], id: int, label: str, notes: str?, region: str, service_type: str, status: str, timeout: int, updated: str(date-time)} # The requested Managed Service.

@endpoint PUT /managed/services/{serviceId}
@desc Managed Service Update
@optional {address: str(url) # The URL at which this Service is monitored.  URL parameters such as `?no-cache=1` are preserved.  URL fragments/anchors such as `#monitor` are **not** preserved., body: str # What to expect to find in the response body for the Service to be considered up., consultation_group: str # The group of ManagedContacts who should be notified or consulted with when an Issue is detected., created: str(date-time) # When this Managed Service was created., credentials: [int] # An array of ManagedCredential IDs that should be used when attempting to resolve issues with this Service., id: int # This Service's unique ID., label: str # The label for this Service. This is for display purposes only., notes: str # Any information relevant to the Service that Linode special forces should know when attempting to resolve Issues., region: str # The Region in which this Service is located. This is required if address is a private IP, and may not be set otherwise., service_type: str(url/tcp) # How this Service is monitored., status: str(disabled/pending/ok/problem) # The current status of this Service., timeout: int # How long to wait, in seconds, for a response before considering the Service to be down., updated: str(date-time) # When this Managed Service was last updated.}
@returns(200) {address: str(url), body: str?, consultation_group: str, created: str(date-time), credentials: [int], id: int, label: str, notes: str?, region: str, service_type: str, status: str, timeout: int, updated: str(date-time)} # Service updated successfully.

@endpoint POST /managed/services/{serviceId}/disable
@desc Managed Service Disable
@returns(200) {address: str(url), body: str?, consultation_group: str, created: str(date-time), credentials: [int], id: int, label: str, notes: str?, region: str, service_type: str, status: str, timeout: int, updated: str(date-time)} # Service disabled.

@endpoint POST /managed/services/{serviceId}/enable
@desc Managed Service Enable
@returns(200) {address: str(url), body: str?, consultation_group: str, created: str(date-time), credentials: [int], id: int, label: str, notes: str?, region: str, service_type: str, status: str, timeout: int, updated: str(date-time)} # Service enabled.

@endpoint GET /managed/stats
@desc Managed Stats List
@returns(200) {data: map} # A list of Managed Stats from the last 24 hours.

@endpoint GET /networking/firewalls
