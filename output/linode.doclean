@endpoint POST /support/tickets
@desc Support Ticket Open
@required {description: str # The full details of the issue or question., summary: str # The summary or title for this SupportTicket.}
@optional {database_id: int # The ID of the Managed Database this ticket is regarding, if relevant., domain_id: int # The ID of the Domain this ticket is regarding, if relevant., firewall_id: int # The ID of the Firewall this ticket is regarding, if relevant., linode_id: int # The ID of the Linode this ticket is regarding, if relevant., lkecluster_id: int # The ID of the Kubernetes cluster this ticket is regarding, if relevant., longviewclient_id: int # The ID of the Longview client this ticket is regarding, if relevant., managed_issue: bool # Designates if this ticket is related to a [Managed service](https://www.linode.com/products/managed/). If `true`, the following constraints will apply: * No ID attributes (i.e. `linode_id`, `domain_id`, etc.) should be provided with this request. * Your account must have a [Managed service enabled](/docs/api/managed/#managed-service-enable)., nodebalancer_id: int # The ID of the NodeBalancer this ticket is regarding, if relevant., region: str # The [Region](/docs/api/regions/) ID for the associated VLAN this ticket is regarding.  Only allowed when submitting a VLAN ticket., vlan: str # The label of the VLAN this ticket is regarding, if relevant. To view your VLANs, use the VLANs List ([GET /networking/vlans](/docs/api/networking/#vlans-list)) endpoint.  Requires a specified `region` to identify the VLAN., volume_id: int # The ID of the Volume this ticket is regarding, if relevant.}
@returns(200) {attachments: [str], closable: bool, closed: str(date-time)?, description: str, entity: map?{id: int, label: str, type: str, url: str}, gravatar_id: str, id: int, opened: str(date-time), opened_by: str, status: str, summary: str, updated: str(date-time), updated_by: str?} # Support Ticket opened.

