@endpoint GET /profile/tokens
@desc Personal Access Tokens List
@returns(200) {data: [map], page: int, pages: int, results: int} # A paginated list of active tokens.

@endpoint POST /profile/tokens
@desc Personal Access Token Create
@optional {expiry: str(date-time) # When this token should be valid until.  If omitted, the new token will be valid until it is manually revoked., label: str # This token's label.  This is for display purposes only, but can be used to more easily track what you're using each token for., scopes: str(oauth-scope) # The scopes to create the token with.  These cannot be changed after creation, and may not exceed the scopes of the acting token. If omitted, the new token will have the same scopes as the acting token.}
@returns(200) {created: str(date-time), expiry: str(date-time), id: int, label: str, scopes: str(oauth-scopes), token: str} # Token created successfully.

@endpoint DELETE /profile/tokens/{tokenId}
@desc Personal Access Token Revoke
@returns(200) Token revoked successfully.

@endpoint GET /profile/tokens/{tokenId}
@desc Personal Access Token View
@returns(200) {created: str(date-time), expiry: str(date-time), id: int, label: str, scopes: str(oauth-scopes), token: str} # The requested token.

@endpoint PUT /profile/tokens/{tokenId}
@desc Personal Access Token Update
@optional {created: str(date-time) # The date and time this token was created., expiry: str(date-time) # When this token will expire.  Personal Access Tokens cannot be renewed, so after this time the token will be completely unusable and a new token will need to be generated.  Tokens may be created with "null" as their expiry and will never expire unless revoked., id: int # This token's unique ID, which can be used to revoke it., label: str # This token's label.  This is for display purposes only, but can be used to more easily track what you're using each token for., scopes: str(oauth-scopes) # The scopes this token was created with. These define what parts of the Account the token can be used to access. Many command-line tools, such as the <a target="_top" href="https://github.com/linode/linode-cli">Linode CLI</a>, require tokens with access to `*`. Tokens with more restrictive scopes are generally more secure., token: str # The token used to access the API.  When the token is created, the full token is returned here.  Otherwise, only the first 16 characters are returned.}
@returns(200) {created: str(date-time), expiry: str(date-time), id: int, label: str, scopes: str(oauth-scopes), token: str} # Token updated successfully.

