@returns(200) {data: [map], page: int, pages: int, results: int} # Returns an array of Firewalls.

@endpoint POST /networking/firewalls
@desc Firewall Create
@required {rules: any}
@optional {devices: map # Devices to create for this Firewall. When a Device is created, the Firewall is assigned to its associated service. Currently, Devices can only be created for Linode instances.}
@returns(200) {created: str(date-time), id: int, label: str, rules: map{inbound: [map], inbound_policy: str, outbound: [map], outbound_policy: str}, status: str, tags: [str], updated: str(date-time)} # Returns information about the created Firewall.

@endpoint DELETE /networking/firewalls/{firewallId}
@desc Firewall Delete
@returns(200) Delete Successful.

@endpoint GET /networking/firewalls/{firewallId}
@desc Firewall View
@returns(200) {created: str(date-time), id: int, label: str, rules: map{inbound: [map], inbound_policy: str, outbound: [map], outbound_policy: str}, status: str, tags: [str], updated: str(date-time)} # Returns information about this Firewall.

@endpoint PUT /networking/firewalls/{firewallId}
@desc Firewall Update
@optional {label: str # The Firewall's label, for display purposes only.  Firewall labels have the following constraints:    * Must begin and end with an alphanumeric character.   * May only consist of alphanumeric characters, dashes (`-`), underscores (`_`) or periods (`.`).   * Cannot have two dashes (`--`), underscores (`__`) or periods (`..`) in a row.   * Must be between 3 and 32 characters.   * Must be unique., status: str(enabled/disabled) # The status to be applied to this Firewall.    * When a Firewall is first created its status is `enabled`.  * Use the [Delete Firewall](/docs/api/networking/#firewall-delete) endpoint to delete a Firewall., tags: [str] # An array of tags applied to this object. Tags are for organizational purposes only.}
@returns(200) {created: str(date-time), id: int, label: str, rules: map{inbound: [map], inbound_policy: str, outbound: [map], outbound_policy: str}, status: str, tags: [str], updated: str(date-time)} # Firewall updated successfully.

@endpoint GET /networking/firewalls/{firewallId}/devices
@desc Firewall Devices List
@optional {page: int=1 # The page of a collection to return., page_size: int=100 # The number of items to return per page.}
@returns(200) {data: [map], page: int, pages: int, results: int} # A paginated list of Firewall Devices

@endpoint POST /networking/firewalls/{firewallId}/devices
@desc Firewall Device Create
@returns(200) {created: str(date-time), entity: map{id: int, label: str, type: str, url: str(url)}, id: int, updated: str(date-time)} # Returns information about the created Firewall Device.

@endpoint DELETE /networking/firewalls/{firewallId}/devices/{deviceId}
@desc Firewall Device Delete
