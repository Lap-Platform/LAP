@endpoint GET /networking/firewalls/{firewallId}/devices/{deviceId}
@desc Firewall Device View
@returns(200) {created: str(date-time), entity: map{id: int, label: str, type: str, url: str(url)}, id: int, updated: str(date-time)} # The requested Firewall Device.

