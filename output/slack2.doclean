@desc List all approved workspace invite requests.
@required {token: str # Authentication token. Requires scope: `admin.invites:read`}
@optional {team_id: str # ID for the workspace where the invite requests were made., cursor: str # Value of the `next_cursor` field sent as part of the previous API response, limit: int # The number of results that will be returned by the API on each invocation. Must be between 1 - 1000, both inclusive}
@returns(200) {ok: bool} # Typical success response

@endpoint GET /admin.inviteRequests.denied.list
@desc List all denied workspace invite requests.
@required {token: str # Authentication token. Requires scope: `admin.invites:read`}
@optional {team_id: str # ID for the workspace where the invite requests were made., cursor: str # Value of the `next_cursor` field sent as part of the previous api response, limit: int # The number of results that will be returned by the API on each invocation. Must be between 1 - 1000 both inclusive}
@returns(200) {ok: bool} # Typical success response

@endpoint POST /admin.inviteRequests.deny
@desc Deny a workspace invite request.
@required {token: str # Authentication token. Requires scope: `admin.invites:write`}
@returns(200) {ok: bool} # Typical success response

@endpoint GET /admin.inviteRequests.list
@desc List all pending workspace invite requests.
@required {token: str # Authentication token. Requires scope: `admin.invites:read`}
@optional {team_id: str # ID for the workspace where the invite requests were made., cursor: str # Value of the `next_cursor` field sent as part of the previous API response, limit: int # The number of results that will be returned by the API on each invocation. Must be between 1 - 1000, both inclusive}
@returns(200) {ok: bool} # Typical success response

@endpoint GET /admin.teams.admins.list
@desc List all of the admins on a given workspace.
@required {token: str # Authentication token. Requires scope: `admin.teams:read`, team_id: str}
@optional {limit: int # The maximum number of items to return., cursor: str # Set `cursor` to `next_cursor` returned by the previous call to list items in the next page.}
@returns(200) {ok: bool} # Typical success response

