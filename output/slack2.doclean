@endpoint GET /admin.usergroups.listChannels
@desc List the channels linked to an org-level IDP group (user group).
@required {token: str # Authentication token. Requires scope: `admin.usergroups:read`, usergroup_id: str # ID of the IDP group to list default channels for.}
@optional {team_id: str # ID of the the workspace., include_num_members: bool # Flag to include or exclude the count of members per channel.}
@returns(200) {ok: bool} # Typical success response

