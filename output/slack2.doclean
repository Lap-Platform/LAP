@endpoint GET /api.test
@desc Checks API calling code.
@optional {error: str # Error response to return, foo: str # example property to return}
@returns(200) {ok: bool} # Standard success response

@endpoint GET /apps.event.authorizations.list
@desc Get a list of authorizations for the given event context. Each authorization represents an app installation that the event is visible to.
@required {token: str # Authentication token. Requires scope: `authorizations:read`, event_context: str}
@optional {cursor: str, limit: int}
@returns(200) {ok: bool} # Typical success response

@endpoint GET /apps.permissions.info
@desc Returns list of permissions this app has on a team.
@optional {token: str # Authentication token. Requires scope: `none`}
@returns(200) {info: map{app_home: map{resources: map, scopes: [str]}, channel: map{resources: map, scopes: [str]}, group: map{resources: map, scopes: [str]}, im: map{resources: map, scopes: [str]}, mpim: map{resources: map, scopes: [str]}, team: map{resources: map, scopes: [str]}}, ok: bool} # Standard success response when used with a user token

@endpoint GET /apps.permissions.request
@desc Allows an app to request additional scopes
@required {token: str # Authentication token. Requires scope: `none`, scopes: str # A comma separated list of scopes to request for, trigger_id: str # Token used to trigger the permissions API}
@returns(200) {ok: bool} # Standard success response when used with a user token

@endpoint GET /apps.permissions.resources.list
@desc Returns list of resource grants this app has on a team.
@required {token: str # Authentication token. Requires scope: `none`}
@optional {cursor: str # Paginate through collections of data by setting the `cursor` parameter to a `next_cursor` attribute returned by a previous request's `response_metadata`. Default value fetches the first "page" of the collection. See [pagination](/docs/pagination) for more detail., limit: int # The maximum number of items to return.}
@returns(200) {ok: bool, resources: [map], response_metadata: map{next_cursor: str}} # Typical successful paginated response

@endpoint GET /apps.permissions.scopes.list
@desc Returns list of scopes this app has on a team.
@required {token: str # Authentication token. Requires scope: `none`}
@returns(200) {ok: bool, scopes: map{app_home: [str], channel: [str], group: [str], im: [str], mpim: [str], team: [str], user: [str]}} # Typical successful paginated response

@endpoint GET /apps.permissions.users.list
@desc Returns list of user grants and corresponding scopes this app has on a team.
@required {token: str # Authentication token. Requires scope: `none`}
@optional {cursor: str # Paginate through collections of data by setting the `cursor` parameter to a `next_cursor` attribute returned by a previous request's `response_metadata`. Default value fetches the first "page" of the collection. See [pagination](/docs/pagination) for more detail., limit: int # The maximum number of items to return.}
@returns(200) {ok: bool} # Typical successful paginated response

@endpoint GET /apps.permissions.users.request
@desc Enables an app to trigger a permissions modal to grant an app access to a user access scope.
@required {token: str # Authentication token. Requires scope: `none`, scopes: str # A comma separated list of user scopes to request for, trigger_id: str # Token used to trigger the request, user: str # The user this scope is being requested for}
@returns(200) {ok: bool} # Standard success response when used with a user token

@endpoint GET /apps.uninstall
@desc Uninstalls your app from a workspace.
@optional {token: str # Authentication token. Requires scope: `none`, client_id: str # Issued when you created your application., client_secret: str # Issued when you created your application.}
@returns(200) {ok: bool} # Typical success response

@endpoint GET /auth.revoke
@desc Revokes a token.
@required {token: str # Authentication token. Requires scope: `none`}
@optional {test: bool # Setting this parameter to `1` triggers a _testing mode_ where the specified token will not actually be revoked.}
@returns(200) {ok: bool, revoked: bool} # Typical success response

@endpoint GET /auth.test
@desc Checks authentication & identity.
@required {token: str # Authentication token. Requires scope: `none`}
@returns(200) {bot_id: str, is_enterprise_install: bool, ok: bool, team: str, team_id: str, url: str, user: str, user_id: str} # Standard success response when used with a user token

@endpoint GET /bots.info
@desc Gets information about a bot user.
@required {token: str # Authentication token. Requires scope: `users:read`}
@optional {bot: str # Bot user to get info on}
