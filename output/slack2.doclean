@endpoint GET /admin.teams.owners.list
@desc List all of the owners on a given workspace.
@required {token: str # Authentication token. Requires scope: `admin.teams:read`, team_id: str}
@optional {limit: int # The maximum number of items to return. Must be between 1 - 1000 both inclusive., cursor: str # Set `cursor` to `next_cursor` returned by the previous call to list items in the next page.}
@returns(200) {ok: bool} # Typical success response

