@desc List emoji for an Enterprise Grid organization.
@required {token: str # Authentication token. Requires scope: `admin.teams:read`}
@optional {cursor: str # Set `cursor` to `next_cursor` returned by the previous call to list items in the next page, limit: int # The maximum number of items to return. Must be between 1 - 1000 both inclusive.}
@returns(200) {ok: bool} # Typical success response

@endpoint POST /admin.emoji.remove
@desc Remove an emoji across an Enterprise Grid organization
@returns(200) {ok: bool} # Typical success response

@endpoint POST /admin.emoji.rename
@desc Rename an emoji.
@returns(200) {ok: bool} # Typical success response

