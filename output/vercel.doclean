@endpoint DELETE /v1/teams/{teamId}/members/{uid}
@desc Remove a Team Member
@required {uid: str # The user ID of the member., teamId: str # Automatically added}
@returns(200) {id: str} # Successfully removed a member of the team.
@errors {400: One of the provided values in the request query is invalid.
Cannot leave the team as the only owner., 403: You do not have permission to access this resource.
Not authorized to update the team., 404: A user with the specified ID does not exist.
No team found.}

@endpoint PATCH /v1/teams/{teamId}/members/{uid}
@desc Update a Team Member
@required {uid: str # The ID of the member., teamId: str # Automatically added}
@optional {confirmed: bool # Accept a user who requested access to the team., joinedFrom: map, role: str=['MEMBER', 'VIEWER'] # The role in the team of the member.}
@returns(200) {id: str} # Successfully updated the membership.
@errors {400: One of the provided values in the request body is invalid.
One of the provided values in the request query is invalid.
Cannot disconnect SSO from a Team member that does not have a SSO connection.
Cannot confirm a member that is already confirmed.
Cannot confirm a member that did not request access., 401: Team members can only be updated by an owner, or by the authenticated user if they are only disconnecting their SAML connection to the Team., 402, 403: You do not have permission to access this resource., 404: The provided user is not part of this team.
A user with the specified ID does not exist.
Team not found.}

