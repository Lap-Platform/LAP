@required {userId: str, teamId: str # Automatically added}
@returns(200) {accessRequestedAt: num, bitbucket: map?, confirmed: bool, github: map?, gitlab: map?, joinedFrom: map{commitId: str, dsyncConnectedAt: num, dsyncUserId: str, gitUserId: any, gitUserLogin: str, idpUserId: str, origin: str, repoId: str, repoPath: str, ssoConnectedAt: num, ssoUserId: str}, teamName: str, teamSlug: str} # Successfully
@errors {400: One of the provided values in the request query is invalid.
