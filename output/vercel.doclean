@endpoint POST /registration
@desc Login with email
@required {email: str # The user email.}
@optional {tokenName: str # The desired name for the token. It will be displayed on the user account details.}
@returns(200) {securityCode: str, token: str} # The request was successful and an email was sent
@errors {400: One of the provided values in the request body is invalid.
The provided email is invalid because the owner is blocked}

@endpoint GET /registration/verify
@desc Verify a login request to get an authentication token
@required {token: str # The token returned when the login was requested.}
@optional {email: str # Email to verify the login., tokenName: str # The desired name for the token. It will be displayed on the user account details., ssoUserId: str # The SAML Profile ID, when connecting a SAML Profile to a Team member for the first time.}
@returns(200) {email: str, teamId: str, token: str} # The verification was successful.
@errors {400: One of the provided values in the request query is invalid.
The provided token exists but is not yet confirmed, 403: You do not have permission to access this resource.
The verification sso token is invalid or not found
The verification token is invalid or not found, 404}

@endpoint GET /v1/deployments/{deploymentId}/checks
