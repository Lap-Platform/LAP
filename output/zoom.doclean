@optional {page_size: int=30 # The number of records returned within a single API call., page_number: int=1 # **Deprecated** - This field has been deprecated and we will stop supporting it completely in a future release. Please use "next_page_token" for pagination instead of this field.  The page number of the current page in the returned records., next_page_token: str # The next page token is used to paginate through large result sets. A next page token will be returned whenever the set of available results exceeds the current page size. The expiration period for this token is 15 minutes.}
@returns(200) **HTTP Status Code:** `200`<br>
List of H.323/SIP devices returned.<br>
**Error Code:** `200`<br>
No permission.

@endpoint POST /h323/devices
@desc Create a H.323/SIP device
@required {encryption: str(auto/True/False) # Device encryption:<br>`auto` - auto.<br>`yes` - yes.<br>`no` - no., ip: str # Device IP., name: str # Device name., protocol: str(H.323/SIP) # Device protocol:<br>`H.323` - H.323.<br>`SIP` - SIP.}
@returns(200) **Error Code:** `200`<br>
No permission.
@returns(201) **HTTP Status Code:** `201`<br>
H.323/SIP device created.
@errors {404: **HTTP Status Code:** `404`<br>
**Error Code:** `2020`<br>
H.323 device's display name:{displayName} is already in use.
}

@endpoint DELETE /h323/devices/{deviceId}
@desc Delete a H.323/SIP device
@required {deviceId: str # The device ID.}
@returns(200) You do not have the permission to delete this device.
@returns(204) H.323/SIP device deleted.
@errors {300: H.323 device does not exist: {deviceId}., 404: H.323/SIP device not found.}

@endpoint PATCH /h323/devices/{deviceId}
@desc Update a H.323/SIP device
@required {deviceId: str # The device ID., encryption: str(auto/True/False) # Device encryption:<br>`auto` - auto.<br>`yes` - yes.<br>`no` - no., ip: str # Device IP., name: str # Device name., protocol: str(H.323/SIP) # Device protocol:<br>`H.323` - H.323.<br>`SIP` - SIP.}
@returns(204) **HTTP Status Code:** `204`<br>
H.323/SIP device updated.
@errors {300: **Error Code:** `300`<br>
H.323 Device does not exist: {deviceId}., 404: **HTTP Status Code:** `404`<br>
**Error Code:** `2020`<br>
H.323 device's display name:{displayName} is already in use.
}

@endpoint POST /im/chat/messages
@desc Send chatbot messages
@required {account_id: str # Account ID of the authorized account., content: map # JSON template describing how the message should be displayed for the user. For more information please see our ["Send Message" templates](https://marketplace.zoom.us/docs/guides/chatbots/sending-messages#example-request)., robot_jid: str # Robot JID created when enabling chatbot features on your marketplace app., to_jid: str # Unique JID of reciever. Can be a group or user.}
@optional {is_markdown_support: bool # **Optional**<br> Applies the markdown parser to your chatbot message if the value of this field is set to `true`.<br> To learn more, refer to the Chatbot message [markdown reference](https://marketplace.zoom.us/docs/guides/chatbots/customizing-messages/message-with-markdown)., user_jid: str # **Optional**<br> The UserJID of the user on whose behalf the message is being sent. Use this field to prevent members of a channel from getting notifications that were set up by a user who has left the channel., visible_to_user: str # **Optional**<br>Allow a Chatbot to send a message to a group channel, but have only one designated person in that group channel see the message by providing the person's UserID in this field.}
@returns(200) **HTTP Status Code:** `200` **OK**<br>
Message Sent.
@errors {400: **HTTP Status Code:** `400` **Bad Request**<br>
**Error Code:** `7001`<br>
Link does not support markdown format.<br>
Edit message does not support markdown format.}

@endpoint DELETE /im/chat/messages/{message_id}
@desc Delete a chatbot message
@required {account_id: str # The AccountID of the Zoom account to which the message was sent. Retrieve this from the Chatbot request sent to your server as shown in the example [here]( https://marketplace.zoom.us/docs/guides/chatbots/sending-messages)., robot_jid: str # The BotJID found in the Chat Subscription Section on the Features page of your App Dashboard.}
@optional {user_jid: str # The UserJID of the user on whose behalf the message is being sent. Used to prevent members of a channel from getting notifications that were set up by a user who has left the channel.}
@returns(200) {message_id: str, robot_jid: str, sent_time: str, to_jid: str, user_jid: str} # **HTTP Status Code:** `200` **OK**<br>
Message deleted.

@endpoint PUT /im/chat/messages/{message_id}
@desc Edit a chatbot message
@required {message_id: str # Unique Identifier of the message that needs to be updated. This should be retrieved from the response of [Send Chatbot Message API](https://marketplace.zoom.us/docs/api-reference/zoom-api/im-chat/sendchatbot)., account_id: str # The AccountID of the Zoom account to which the message was sent. Retrieve this from the Chatbot request sent to your server as shown in the example [here]( https://marketplace.zoom.us/docs/guides/chatbots/sending-messages)., content: map # JSON template describing how the edited message should be displayed for the user. For more information please see our ["Send Message" templates](https://marketplace.zoom.us/docs/guides/chatbots/sending-messages#example-request)., robot_jid: str # Robot JID created when enabling chatbot features on your marketplace app.}
@optional {is_markdown_support: bool # **Optional**<br> Enable or disable markdown parser to your chatbot message. Applies the markdown parser to your chatbot message if the value of this field is set to `true`.<br> To learn more, refer to the Chatbot message [markdown reference](https://marketplace.zoom.us/docs/guides/chatbots/customizing-messages/message-with-markdown)., user_jid: str # **Optional**<br> The UserJID of the user on whose behalf the message is being sent. Use this field to prevent members of a channel from getting notifications that were set up by a user who has left the channel.}
@returns(200) {message_id: str, robot_jid: str, sent_time: str(date-time), to_jid: str, user_jid: str} # **HTTP Status Code:** `200` **OK**<br>
Message updated.

@endpoint GET /im/chat/sessions
@desc Get IM chat sessions
@required {from: str(date) # Start date in 'yyyy-mm-dd' format. The date range defined by the "from" and "to" parameters should only be one month as the report includes only one month worth of data at once., to: str(date) # End date.}
@optional {page_size: int=30 # The number of records returned within a single API call., next_page_token: str # The next page token is used to paginate through large result sets. A next page token will be returned whenever the set of available results exceeds the current page size. The expiration period for this token is 15 minutes.}
