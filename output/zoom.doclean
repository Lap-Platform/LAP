@endpoint GET /accounts
@desc List sub accounts
@optional {page_size: int=30 # The number of records returned within a single API call., page_number: int=1 # **Deprecated** - This field has been deprecated and we will stop supporting it completely in a future release. Please use "next_page_token" for pagination instead of this field.  The page number of the current page in the returned records., next_page_token: str # The next page token is used to paginate through large result sets. A next page token will be returned whenever the set of available results exceeds the current page size. The expiration period for this token is 15 minutes.}
@returns(200) Account list returned.

@endpoint POST /accounts
@desc Create a sub account
@required {email: str # User's email address., first_name: str # User's first name., last_name: str # User's last name., password: str # User's password.  **Note:** If the account owner or admin has enabled [enhanced password requirements](https://support.zoom.us/hc/en-us/articles/360034675592-Advanced-security-settings#h_fa9186e4-6818-4f7a-915c-2e25c19f0acd), the value provided in this field must meet those requirements. These requirements can be retrieved by calling the [Get Account Settings API](https://marketplace.zoom.us/docs/api-reference/zoom-api/accounts/accountsettings) and referring to the `password_requirement` field present in the `security` object.}
@optional {account_name: str # Name of the account. If you do not provide a value for this field, by default, the value will be set as a concatenation of "first_name" and "last_name"., options: map # Account options object.}
@returns(201) {created_at: str, id: str, owner_email: str, owner_id: str} # Account created.
@errors {400: **HTTP Status Code:** `400`<br>
**Error Code:**`300`<br> Your request could not be completed because the name contains an invalid word: {name}
**Error Code:** `1107`<br>
Email domain is blocked.<br>
**Error Code:** `1111`<br>
Password should not contain repeated characters such as 'aaaaaa'. <br>
Password should not contain consecutive characters such as 'abc','123'.

, 409: **HTTP Status Code:** `409`<br>
**Error Code:** `1005`<br>
Email $email has already been used.}

@endpoint DELETE /accounts/{accountId}
@desc Disassociate a sub account
@required {accountId: str # The account ID.}
@returns(204) **HTTP Status Code**: `204`<br>Account deleted.
@errors {404: **HTTP Status Code**: `404` <br> 
**Error Code:** `2000`<br> You cannot disassociate a paid account. <br>
**Error Code:** `2001`<br> Account does not exist: $subAccountId.}

@endpoint GET /accounts/{accountId}
@desc Get sub account details
@required {accountId: str # The account ID.}
@returns(200) {created_at: str(date-time), id: str, options: map{billing_auto_renew: bool, meeting_connector_list: [str], pay_mode: str, room_connector_list: [str], share_mc: bool, share_rc: bool}, owner_email: str, owner_id: str, vanity_url: str} # **HTTP Status Code**: `200`<br>
Account object returned.
@errors {404: **HTTP Status Code**: `404`<br>
**Error Code:** `2001`<br> Account does not exist: $subAccountId.}

@endpoint GET /accounts/{accountId}/billing
@desc Get billing information
@required {accountId: str # The account ID.}
@returns(200) {address: str, apt: str, city: str, country: str, email: str, first_name: str, last_name: str, phone_number: str, state: str, zip: str} # **HTTP Status Code:** `200`<br>
Account billing contact information returned.
@errors {400: **HTTP Status Code:** `400`<br>
**Error Code:** `2100`<br> 
This sub account is on self pay mode., 404: **HTTP Status Code:** `404`<br>
**Error Code:** `2001`<br>
Account does not exist: {subAccountId}.


}

@endpoint PATCH /accounts/{accountId}/billing
@desc Update billing information
@required {accountId: str # The account ID.}
@optional {address: str # Billing Contact's address., apt: str # Billing Contact's apartment/suite., city: str # Billing Contact's city., country: str # Billing Contact's country., email: str # Billing Contact's email address., first_name: str # Billing Contact's first name., last_name: str # Billing Contact's last name., phone_number: str # Billing Contact's phone number., state: str # Billing Contact's state., zip: str # Billing Contact's zip/postal code.}
@returns(200) **Error Code:** `200`<br>
Please subscribe a plan for this sub account first.
@returns(204) **HTTP Status Code:** `204`<br>
Account billing contact information updated.
@errors {400: **HTTP Status Code:** `400`<br>
**Error Code:** `2100`<br>
This sub account is on self pay mode.<br>
Invalid country parameter: {country}.<br>
Invalid state parameter: {state}., 404: **HTTP Status Code:** `404`<br>
**Error Code:** `2001`<br>
Account does not exist: {subAccountId}.



}

@endpoint GET /accounts/{accountId}/billing/invoices
@desc List billing invoices
@optional {from: str(date) # Start date for the invoice query in `yyyy-mm-dd` format. The date range defined by the “from” and “to” parameters should not exceed one year. The range defined should fall within the past three years., to: str(date) # End date for the invoice query in `yyyy-mm-dd` format}
@returns(200) {currency: str, invoices: [map]} # **HTTP Status Code:** `200`<br>
Account billing invoice information returned.
@errors {400: **HTTP Status Code:** `400`<br>
**Error Code:** `200`<br>
Only available for Paid account: {subAccountId}.
**Error Code:** `2001`<br>
Account does not exist: {subAccountId}.}

@endpoint GET /accounts/{accountId}/billing/invoices/{invoiceId}
@desc Get invoice details
@returns(200) {balance: num(double), currency: str, due_date: str, id: str, invoice_date: str, invoice_items: [map], invoice_number: str, status: str, target_date: str, tax_amount: num(double), total_amount: num(double)} # **HTTP Status Code:** `200`<br>
Account billing invoice information returned.
@errors {400: **HTTP Status Code:** `400`<br>
**Error Code:** `2001`<br>
Account does not exist: {subAccountId}.<br>
InvoiceId does not exist: {invoiceId}.}

@endpoint GET /accounts/{accountId}/lock_settings
@desc Get locked settings
@required {accountId: str # Unique Identifier of the account. To retrieve locked settings of the master account or a regular account, provide "me" as the value of this field. <br> To retrieve locked settings of a sub account, provide the Account ID of the sub account in this field.}
@optional {option: str # `meeting_security`: Use this query parameter to view meeting security settings applied on the account.<br>, custom_query_fields: str # Provide the name of the field by which you would like to filter the response. For example, if you provide "host_video" as the value of this field, you will get a response similar to the following:<br> {     "schedule_meeting": {         "host_video": false     } } <br>You can provide multiple values by separating them with commas(example: "host_video,participant_video”).}
@returns(200) **Error Code:** `200`<br>
Only available for paid account:$accountId.

**HTTP Status Code:** `200`<br>
Locked settings for the Account returned.


@errors {400: **HTTP Status Code:** `400`<br>
**Error Code:** `2001`<br>
Account does not exist: $subAccountId.}

@endpoint PATCH /accounts/{accountId}/lock_settings
@desc Update locked settings
@required {accountId: str # Unique Identifier of the account. To retrieve locked settings of the master account or a regular account, provide "me" as the value of this field. <br> To retrieve locked settings of a sub account, provide the Account ID of the sub account in this field.}
@returns(200) **Error Code:** `200`<br>
Only available for Paid account: $accountId.

@returns(204) **HTTP Status Code:** `204`<br>
Account lock settings updated.
@errors {404: **HTTP Status Code:** `404`<br>
**Error Code:** `2001`<br>
TAccount does not exist: $subAccountId.
}

@endpoint GET /accounts/{accountId}/managed_domains
@desc Get managed domains
@required {accountId: str # Unique Identifier of the account. To retrieve locked settings of the master account or a regular account, provide "me" as the value of this field. <br> To retrieve locked settings of a sub account, provide the Account ID of the sub account in this field.}
@returns(200) {domains: [map], total_records: int} # **HTTP Status Code:** `200`<br>
Account managed domains returned.
**Error Code:** `200`<br>
Only available for paid account.


@errors {404: **HTTP Status Code:** `404`<br>
**Error Code**: `2001`<br>
Account does not exist: $subAccountId.
}

@endpoint PATCH /accounts/{accountId}/options
@desc Update options
@required {accountId: str # The account ID.}
@optional {billing_auto_renew: bool # Toggle whether automatic billing renewal is on or off., meeting_connector_list: [str] # Specify the IP addresses of the Meeting Connectors that you would like to share with the sub account. Multiple values can be separated by comma. If no value is provided in this field, all the Meeting Connectors of a master account will be shared with the sub account.   **Note:** This option can only be used if the value of `share_mc` is set to `true`., pay_mode: str(master/sub)=master # Payee:<br>`master` - master account holder pays.<br>`sub` - Sub account holder pays., room_connector_list: [str] # Specify the IP addresses of the Room Connectors that you would like to share with the sub account. Multiple values can be separated by comma. If no value is provided in this field, all the Room Connectors of a master account will be shared with the sub account.   **Note:** This option can only be used if the value of `share_rc` is set to `true`., share_mc: bool=False # Enable/disable the option for a sub account to use shared [Meeting Connector(s)](https://support.zoom.us/hc/en-us/articles/201363093-Getting-Started-with-the-Meeting-Connector) that are set up by the master account. Meeting Connectors can only be used by On-prem users., share_rc: bool=False # Enable/disable the option for a sub account to use shared [Virtual Room Connector(s)](https://support.zoom.us/hc/en-us/articles/202134758-Getting-Started-With-Virtual-Room-Connector) that are set up by the master account. Virtual Room Connectors can only be used by On-prem users.}
@returns(200) **Error Code:** `200`<br>
The pay mode cannot be updated for a sub account which already has an existing plan.
@returns(204) **HTTP Status Code:** `204`<br>
Account options updated.
@errors {400: **HTTP Status Code:** `400`<br>
**Error Code:** `2100`<br> The collection method cannot be changed after the purchase is complete., 404: **HTTP Status Code:** `404`<br>
**Error Code:** `2001`<br>
Account does not exist: $subAccountId.}

@endpoint PUT /accounts/{accountId}/owner
@desc Update the account owner
@required {accountId: str # Account Id of the account., email: str(email) # Email address of the new owner.}
@returns(204) **HTTP Status Code:** `204`<br>
Account owner updated.
@errors {400: **HTTP Status Code:** `400`<br>

**Error Code:** `200`<br>
User is not an admin or is an API user or doesn’t belong to this account: {accountId}.<br>
Cannot make a user outside of your account an owner.<br>
Cannot update the role of an account owner., 404: **HTTP Status Code:** `404`<br>
**Error Code:** `2001`<br>
Account does not exist: $subAccountId.<br>
**Error Code:** `3201`<br>
Cannot find a billing account for this: $accountId.<br>
**Error Code:** `3211`<br>
Cannot find a billing contact for this: $accountId.
}

@endpoint PATCH /accounts/{accountId}/phone/settings
@desc Update BYOC settings
@required {accountId: str # Unique identifier of the sub account.}
@optional {byoc: map}
@returns(204) **Response HTTP code**: `204` **No Content.**<br>
Updated successfully.


@errors {401: **HTTP Status Code:** `401`<br>

**Error Code:** `124`<br>
Account does not exist: {accountId}.}

@endpoint POST /accounts/{accountId}/phone/setup
@desc Set up a Zoom Phone account
@required {accountId: str # Unique identifier of the account., emergency_address: map # Specify emergency address for the account., extension_number: str=800 # Specify extension number that will be associated with the owner of the account.}
@returns(201) **HTTP Status Codes** `201`<br>
Created.
@errors {400: **HTTP Response Code:** `400`<br>

**Error Codes:** `300`<br>
The extension number {0} that you entered is a reserved number and can not be used. Provide a different number and try again.<br>
This account is not enrolled in a Zoom Phone plan. Subscribe to a Zoom Phone plan and try again.<br>
The billing information could not be retrieved at this time. Retry the request again after a few seconds.<br>
The country code you entered is invalid. Provide a valid country code and try again.<br>
The state code you entered is invalid. Provide a valid state code and try again.<br>
The city information you entered is invalid. Provide a valid city name and try again.<br>
State code is required for this country.<br>
City is required for this country.<br>
Zip is required for this country.<br>, 401: **HTTP Status Code:** `401`<br>
Unauthorized.<br>

**Error Code:** <br>
`124` Account does not exist: {accountId}.<br>}

@endpoint POST /accounts/{accountId}/phone/sip_trunk/trunks
@desc Assign SIP trunks
@required {accountId: str # Unique identifier of the account.}
@optional {sip_trunks: [map] # SIP trunk configurations.}
@returns(201) {sip_trunks: [map]} # **HTTP Status Code:** `201` **Created** <br>


@errors {404: **HTTP Status Code:** `404` <br>
SIP Trunk does not exist: {sipTruniId}}

@endpoint PATCH /accounts/{accountId}/phone/sip_trunk/trunks/{sipTrunkId}
@desc Update SIP trunk details
@required {sipTrunkId: str # Unique identifier of the SIP trunk., accountId: str # Unique identifier of the sub account.}
@optional {carrier_account: str # Account associated with the carrier., name: str # Name of the SIP Trunk.}
@returns(204) **HTTP Response Code**: `204` **No Content**<br>

@errors {404: **HTTP Status Code:** `404` <br>
Sip trunk does not exist: {0}.}

@endpoint GET /accounts/{accountId}/plans
@desc Get plan Information
@required {accountId: str # The account ID.}
@returns(200) {plan_audio: map{callout_countries: str, ddi_numbers: int, next_invoice_date: str, premium_countries: str, service_effective_date: str, status: str, tollfree_countries: str, type: str}, plan_base: map{hosts: int, next_invoice_date: str, service_effective_date: str, status: str, type: str}, plan_large_meeting: [map], plan_phone: map{plan_base: map{callout_countries: str, next_invoice_date: str, service_effective_date: str, status: str, type: str}, plan_calling: [map], plan_number: [map]}, plan_recording: str, plan_recording_next_invoice_date: str, plan_recording_service_effective_date: str, plan_recording_status: str, plan_room_connector: map{hosts: int, next_invoice_date: str, service_effective_date: str, status: str, type: str}, plan_webinar: [map], plan_zoom_rooms: map{hosts: int, next_invoice_date: str, service_effective_date: str, status: str, type: str}} # **HTTP Status Code:**`200`<br>
Account's plans returned.

@errors {400: **HTTP Status Code:** `400`<br>
**Error Code:** `2100`<br> 
This sub account is on self pay mode., 404: **HTTP Status Code:**`404`<br>
Account does not exist: {subAccountId}.}

@endpoint POST /accounts/{accountId}/plans
@desc Subscribe plans
@required {accountId: str # The account ID.}
@returns(200) **Error Code:** `200`<br>
One zuora account only can have one active billing subscription.<br>
Can’t subscribe 25-participants pro plan for this sub-account.<br>
Can’t subscribe 50-participants pro plan for this sub-account.<br>
In order to take advantage of your account’s special pricing, please add Pro host licenses instead and they will be assigned to your Zoom Rooms automatically.
