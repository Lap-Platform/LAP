@endpoint GET /accounts
@optional {page_size: int=30, page_number: int=1, next_page_token: str}
@returns(200)

@endpoint POST /accounts
@required {email: str, first_name: str, last_name: str, password: str}
@optional {account_name: str, options: map}
@returns(201) {created_at: str, id: str, owner_email: str, owner_id: str}
@errors {400, 409}

@endpoint DELETE /accounts/{accountId}
@required {accountId: str}
@returns(204)
@errors {404}

@endpoint GET /accounts/{accountId}
@required {accountId: str}
@returns(200) {created_at: str(date-time), id: str, options: map{billing_auto_renew: bool, meeting_connector_list: [str], pay_mode: str, room_connector_list: [str], share_mc: bool, share_rc: bool}, owner_email: str, owner_id: str, vanity_url: str}
@errors {404}

@endpoint GET /accounts/{accountId}/billing
@required {accountId: str}
@returns(200) {address: str, apt: str, city: str, country: str, email: str, first_name: str, last_name: str, phone_number: str, state: str, zip: str}
@errors {400, 404}

@endpoint PATCH /accounts/{accountId}/billing
@required {accountId: str}
@optional {address: str, apt: str, city: str, country: str, email: str, first_name: str, last_name: str, phone_number: str, state: str, zip: str}
@returns(200)
@returns(204)
@errors {400, 404}

@endpoint GET /accounts/{accountId}/billing/invoices
@optional {from: str(date), to: str(date)}
@returns(200) {currency: str, invoices: [map]}
@errors {400}

@endpoint GET /accounts/{accountId}/billing/invoices/{invoiceId}
@returns(200) {balance: num(double), currency: str, due_date: str, id: str, invoice_date: str, invoice_items: [map], invoice_number: str, status: str, target_date: str, tax_amount: num(double), total_amount: num(double)}
@errors {400}

@endpoint GET /accounts/{accountId}/lock_settings
@required {accountId: str}
@optional {option: str, custom_query_fields: str}
@returns(200)
@errors {400}

@endpoint PATCH /accounts/{accountId}/lock_settings
@required {accountId: str}
@returns(200)
@returns(204)
@errors {404}

@endpoint GET /accounts/{accountId}/managed_domains
@required {accountId: str}
@returns(200) {domains: [map], total_records: int}
@errors {404}

@endpoint PATCH /accounts/{accountId}/options
@required {accountId: str}
@optional {billing_auto_renew: bool, meeting_connector_list: [str], pay_mode: str(master/sub)=master, room_connector_list: [str], share_mc: bool=False, share_rc: bool=False}
@returns(200)
@returns(204)
@errors {400, 404}

@endpoint PUT /accounts/{accountId}/owner
@required {accountId: str, email: str(email)}
@returns(204)
@errors {400, 404}

@endpoint PATCH /accounts/{accountId}/phone/settings
@required {accountId: str}
@optional {byoc: map}
@returns(204)
@errors {401}

@endpoint POST /accounts/{accountId}/phone/setup
@required {accountId: str, emergency_address: map, extension_number: str=800}
@returns(201)
