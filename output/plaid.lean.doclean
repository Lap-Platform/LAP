@returns(200) {next_cursor: str?, request_id: str, watchlist_programs: [map]}

@endpoint POST /watchlist_screening/individual/review/create
@required {confirmed_hits: [str], dismissed_hits: [str], watchlist_screening_id: str}
@optional {client_id: str, comment: str, secret: str}
@returns(200) {audit_trail: map{dashboard_user_id: str?, source: str, timestamp: str(date-time)}, comment: str?, confirmed_hits: [str], dismissed_hits: [str], id: str, request_id: str}

@endpoint POST /watchlist_screening/individual/review/list
@required {watchlist_screening_id: str}
@optional {client_id: str, cursor: str, secret: str}
@returns(200) {next_cursor: str?, request_id: str, watchlist_screening_reviews: [map]}

@endpoint POST /watchlist_screening/individual/update
@required {watchlist_screening_id: str}
@optional {assignee: str, client_id: str, client_user_id: str, reset_fields: [str], search_terms: map, secret: str, status: str(rejected/pending_review/cleared)}
@returns(200) {assignee: str?, audit_trail: map{dashboard_user_id: str?, source: str, timestamp: str(date-time)}, client_user_id: str?, id: str, request_id: str, search_terms: map{country: str?, date_of_birth: str(date)?, document_number: str?, legal_name: str, version: num, watchlist_program_id: str}, status: str}

@endpoint POST /webhook_verification_key/get
@required {key_id: str}
@optional {client_id: str, secret: str}
@returns(200) {key: map{alg: str, created_at: int, crv: str, expired_at: int?, kid: str, kty: str, use: str, x: str, y: str}, request_id: str}

@end

