@required {tag_id: str # The name of the tag. Tags may contain letters, numbers, colons, dashes, and underscores. There is a limit of 255 characters per tag.}
@returns(200) {tag: any} # The response will be a JSON object with a key called `tag`.  The value of this will be a tag object containing the standard tag attributes.
@errors {401, 404, 429, 500}

@endpoint DELETE /v2/tags/{tag_id}/resources
@desc Untag a Resource
@returns(204)
@errors {401, 404, 429, 500}

@endpoint POST /v2/tags/{tag_id}/resources
@desc Tag a Resource
@required {resources: [any] # An array of objects containing resource_id and resource_type  attributes.}
@returns(204)
@errors {401, 404, 429, 500}

@endpoint GET /v2/uptime/checks
