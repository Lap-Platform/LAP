@doclean v0.2
# Machine-readable API spec. Each @endpoint block is one API call.
@api DigitalOcean API
@base https://api.digitalocean.com
@version 2.0
@auth Bearer bearer
@endpoints 290
@toc List 1-Click Applications, Install Kubernetes 1-Click Applications, Get User Information, List All SSH Keys, Create a New SSH Key, Delete an SSH Key, Retrieve an Existing SSH Key, Update an SSH Key's Name, List All Actions, Retrieve an Existing Action, List All Apps, Create a New App, Retrieve Multiple Apps' Daily Bandwidth Metrics, Propose an App Spec, List App Regions, List App Tiers, List Instance Sizes, Retrieve an Instance Size, Retrieve an App Tier, List all app alerts, Update destinations for alerts, Retrieve Active Deployment Logs, List App Deployments, Create an App Deployment, Retrieve an App Deployment, Cancel a Deployment, Retrieve Deployment Logs, Retrieve Aggregate Deployment Logs, Retrieve Active Deployment Aggregate Logs, Retrieve App Daily Bandwidth Metrics, Rollback App, Commit App Rollback, Revert App Rollback, Validate App Rollback, Delete an App, Retrieve an Existing App, Update an App, List All CDN Endpoints, Create a New CDN Endpoint, Delete a CDN Endpoint, Retrieve an Existing CDN Endpoint, Update a CDN Endpoint, Purge the Cache for an Existing CDN Endpoint, List All Certificates, Create a New Certificate, Delete a Certificate, Retrieve an Existing Certificate, Get Customer Balance, List Billing History, List All Invoices, Retrieve an Invoice by UUID, Retrieve an Invoice CSV by UUID, Retrieve an Invoice PDF by UUID, Retrieve an Invoice Summary by UUID, List All Database Clusters, Create a New Database Cluster, List Database Options, Destroy a Database Cluster, Retrieve an Existing Database Cluster, List Backups for a Database Cluster, Retrieve the Public Certificate, Retrieve an Existing Database Cluster Configuration, Update the Database Configuration for an Existing Database, List All Databases, Add a New Database, Delete a Database, Retrieve an Existing Database, Retrieve the Eviction Policy for a Redis Cluster, Configure the Eviction Policy for a Redis Cluster, List Firewall Rules (Trusted Sources) for a Database Cluster, Update Firewall Rules (Trusted Sources) for a Database, Configure a Database Cluster's Maintenance Window, Migrate a Database Cluster to a New Region, Retrieve the Status of an Online Migration, Start an Online Migration, Stop an Online Migration, List Connection Pools (PostgreSQL), Add a New Connection Pool (PostgreSQL), Delete a Connection Pool (PostgreSQL), Retrieve Existing Connection Pool (PostgreSQL), Update Connection Pools (PostgreSQL), List All Read-only Replicas, Create a Read-only Replica, Destroy a Read-only Replica, Retrieve an Existing Read-only Replica, Promote a Read-only Replica to become a Primary Cluster, Resize a Database Cluster, Retrieve the SQL Modes for a MySQL Cluster, Update SQL Mode for a Cluster, Upgrade Major Version for a Database, List all Database Users, Add a Database User, Remove a Database User, Retrieve an Existing Database User, Reset a Database User's Password or Authentication Method, List All Domains, Create a New Domain, Delete a Domain, Retrieve an Existing Domain, List All Domain Records, Create a New Domain Record, Delete a Domain Record, Retrieve an Existing Domain Record, Update a Domain Record, Update a Domain Record, Deleting Droplets by Tag, List All Droplets, Create a New Droplet, Acting on Tagged Droplets, Delete an Existing Droplet, Retrieve an Existing Droplet, List Actions for a Droplet, Initiate a Droplet Action, Retrieve a Droplet Action, List Backups for a Droplet, List Associated Resources for a Droplet, Destroy a Droplet and All of its Associated Resources (Dangerous), Retry a Droplet Destroy with Associated Resources Request, Selectively Destroy a Droplet and its Associated Resources, Check Status of a Droplet Destroy with Associated Resources Request, List all Firewalls Applied to a Droplet, List All Available Kernels for a Droplet, List Neighbors for a Droplet, List Snapshots for a Droplet, List All Firewalls, Create a New Firewall, Delete a Firewall, Retrieve an Existing Firewall, Update a Firewall, Remove Droplets from a Firewall, Add Droplets to a Firewall, Remove Rules from a Firewall, Add Rules to a Firewall, Remove Tags from a Firewall, Add Tags to a Firewall, List All Floating IPs, Create a New Floating IP, Delete a Floating IP, Retrieve an Existing Floating IP, List All Actions for a Floating IP, Initiate a Floating IP Action, Retrieve an Existing Floating IP Action, List Namespaces, Create Namespace, Delete Namespace, Get Namespace, List Triggers, Create Trigger, Delete Trigger, Get Trigger, Update Trigger, List All Images, Create a Custom Image, Delete an Image, Retrieve an Existing Image, Update an Image, List All Actions for an Image, Initiate an Image Action, Retrieve an Existing Action, List All Kubernetes Clusters, Create a New Kubernetes Cluster, Delete a Kubernetes Cluster, Retrieve an Existing Kubernetes Cluster, Update a Kubernetes Cluster, Fetch Clusterlint Diagnostics for a Kubernetes Cluster, Run Clusterlint Checks on a Kubernetes Cluster, Retrieve Credentials for a Kubernetes Cluster, List Associated Resources for Cluster Deletion, Delete a Cluster and All of its Associated Resources (Dangerous), Selectively Delete a Cluster and its Associated Resources, Retrieve the kubeconfig for a Kubernetes Cluster, List All Node Pools in a Kubernetes Clusters, Add a Node Pool to a Kubernetes Cluster, Delete a Node Pool in a Kubernetes Cluster, Retrieve a Node Pool for a Kubernetes Cluster, Update a Node Pool in a Kubernetes Cluster, Delete a Node in a Kubernetes Cluster, Recycle a Kubernetes Node Pool, Upgrade a Kubernetes Cluster, Retrieve Available Upgrades for an Existing Kubernetes Cluster, Retrieve User Information for a Kubernetes Cluster, List Available Regions, Node Sizes, and Versions of Kubernetes, Remove Container Registry from Kubernetes Clusters, Add Container Registry to Kubernetes Clusters, List All Load Balancers, Create a New Load Balancer, Delete a Load Balancer, Retrieve an Existing Load Balancer, Update a Load Balancer, Remove Droplets from a Load Balancer, Add Droplets to a Load Balancer, Remove Forwarding Rules from a Load Balancer, Add Forwarding Rules to a Load Balancer, List Alert Policies, Create Alert Policy, Delete an Alert Policy, Retrieve an Existing Alert Policy, Update an Alert Policy, Get Droplet Bandwidth Metrics, Get Droplet CPU Metrics, Get Droplet Filesystem Free Metrics, Get Droplet Filesystem Size Metrics, Get Droplet Load1 Metrics, Get Droplet Load15 Metrics, Get Droplet Load5 Metrics, Get Droplet Available Memory Metrics, Get Droplet Cached Memory Metrics, Get Droplet Free Memory Metrics, Get Droplet Total Memory Metrics, List All Projects, Create a Project, Retrieve the Default Project, Patch the Default Project, Update the Default Project, List Default Project Resources, Assign Resources to Default Project, Delete an Existing Project, Retrieve an Existing Project, Patch a Project, Update a Project, List Project Resources, Assign Resources to a Project, List All Data Center Regions, Delete Container Registry, Get Container Registry Information, Create Container Registry, Get Docker Credentials for Container Registry, List Registry Options (Subscription Tiers and Available Regions), Get Subscription Information, Update Subscription Tier, Validate a Container Registry Name, Get Active Garbage Collection, Start Garbage Collection, Update Garbage Collection, List Garbage Collections, List All Container Registry Repositories, List All Container Registry Repositories (V2), List All Container Registry Repository Manifests, Delete Container Registry Repository Manifest, List All Container Registry Repository Tags, Delete Container Registry Repository Tag, List All Droplet Neighbors, List All Reserved IPs, Create a New Reserved IP, Delete a Reserved IP, Retrieve an Existing Reserved IP, List All Actions for a Reserved IP, Initiate a Reserved IP Action, Retrieve an Existing Reserved IP Action, List All Droplet Sizes, List All Snapshots, Delete a Snapshot, Retrieve an Existing Snapshot, List All Tags, Create a New Tag, Delete a Tag, Retrieve a Tag, Untag a Resource, Tag a Resource, List All Checks, Create a New Check, Delete a Check, Retrieve an Existing Check, Update a Check, List All Alerts, Create a New Alert, Delete an Alert, Retrieve an Existing Alert, Update an Alert, Retrieve Check State, Delete a Block Storage Volume by Name, List All Block Storage Volumes, Create a New Block Storage Volume, Initiate A Block Storage Action By Volume Name, Delete a Volume Snapshot, Retrieve an Existing Volume Snapshot, Delete a Block Storage Volume, Retrieve an Existing Block Storage Volume, List All Actions for a Volume, Initiate A Block Storage Action By Volume Id, Retrieve an Existing Volume Action, List Snapshots for a Volume, Create Snapshot from a Volume, List All VPCs, Create a New VPC, Delete a VPC, Retrieve an Existing VPC, Partially Update a VPC, Update a VPC, List the Member Resources of a VPC

@endpoint GET /v2/1-clicks
@desc List 1-Click Applications
@optional {type: str(droplet/kubernetes) # Restrict results to a certain type of 1-Click.}
@returns(200) {1_clicks: [map]} # A JSON object with a key of `1_clicks`.
@errors {401: Unauthorized, 429: API Rate limit exceeded, 500: Server error.}

@endpoint POST /v2/1-clicks/kubernetes
@desc Install Kubernetes 1-Click Applications
@required {addon_slugs: [str]=[] # An array of 1-Click Application slugs to be installed to the Kubernetes cluster., cluster_uuid: str # A unique ID for the Kubernetes cluster to which the 1-Click Applications will be installed.}
@returns(200) {message: str} # The response will verify that a job has been successfully created to install a 1-Click. The
post-installation lifecycle of a 1-Click application can not be managed via the DigitalOcean
API. For additional details specific to the 1-Click, find and view its
[DigitalOcean Marketplace](https://marketplace.digitalocean.com) page.

@errors {401, 429, 500}

@endpoint GET /v2/account
@desc Get User Information
@returns(200) {account: map{droplet_limit: int, email: str, email_verified: bool, floating_ip_limit: int, status: str, status_message: str, team: map{name: str, uuid: str}, uuid: str}} # A JSON object keyed on account with an excerpt of the current user account data.
@errors {401, 429, 500}

@endpoint GET /v2/account/keys
@desc List All SSH Keys
@optional {per_page: int=20 # Number of items returned per page, page: int=1 # Which 'page' of paginated results to return.}
@returns(200) A JSON object with the key set to `ssh_keys`. The value is an array of `ssh_key` objects, each of which contains the standard `ssh_key` attributes.
@errors {401, 429, 500}

@endpoint POST /v2/account/keys
@desc Create a New SSH Key
@returns(201) {ssh_key: any} # The response body will be a JSON object with a key set to `ssh_key`.
@errors {401, 429, 500}

@endpoint DELETE /v2/account/keys/{ssh_key_identifier}
@desc Delete an SSH Key
@returns(204) The action was successful and the response body is empty.
@errors {401, 404, 429, 500}

@endpoint GET /v2/account/keys/{ssh_key_identifier}
@desc Retrieve an Existing SSH Key
@required {ssh_key_identifier: any # Either the ID or the fingerprint of an existing SSH key.}
@returns(200) {ssh_key: any} # A JSON object with the key set to `ssh_key`. The value is an `ssh_key` object containing the standard `ssh_key` attributes.
@errors {401, 404: The resource was not found., 429, 500}

@endpoint PUT /v2/account/keys/{ssh_key_identifier}
@desc Update an SSH Key's Name
@optional {name: any}
@returns(200)
@errors {401, 404, 429, 500}

@endpoint GET /v2/actions
@desc List All Actions
@returns(200) The results will be returned as a JSON object with an actions key.  This will be set to an array filled with action objects containing the standard action attributes
@errors {401, 429, 500}

@endpoint GET /v2/actions/{action_id}
@desc Retrieve an Existing Action
@required {action_id: int # A unique numeric ID that can be used to identify and reference an action.}
@returns(200) {action: any} # The result will be a JSON object with an action key.  This will be set to an action object containing the standard action attributes.
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps
@desc List All Apps
@optional {with_projects: bool # Whether the project_id of listed apps should be fetched and included.}
@returns(200) A JSON object with a `apps` key. This is list of object `apps`.
@errors {401, 429, 500}

@endpoint POST /v2/apps
@desc Create a New App
@required {spec: any}
@optional {Accept: str(application/json/application/yaml) # The content-type that should be used by the response. By default, the response will be `application/json`. `application/yaml` is also supported., Content-Type: str(application/json/application/yaml) # The content-type used for the request. By default, the requests are assumed to use `application/json`. `application/yaml` is also supported., project_id: str # The ID of the project the app should be assigned to. If omitted, it will be assigned to your default project.}
@returns(200) {app: any} # A JSON or YAML of a `spec` object.
@errors {401, 429, 500}

@endpoint POST /v2/apps/metrics/bandwidth_daily
@desc Retrieve Multiple Apps' Daily Bandwidth Metrics
@required {app_ids: [str] # A list of app IDs to query bandwidth metrics for.}
@optional {date: str(date-time) # Optional day to query. Only the date component of the timestamp will be considered. Default: yesterday.}
@returns(200) A JSON object with a `app_bandwidth_usage` key
@errors {401, 404, 429, 500}

@endpoint POST /v2/apps/propose
@desc Propose an App Spec
@required {spec: any}
@optional {app_id: str # An optional ID of an existing app. If set, the spec will be treated as a proposed update to the specified app. The existing app is not modified using this method.}
@returns(200) {app_cost: int(int32), app_is_static: bool, app_name_available: bool, app_name_suggestion: str, app_tier_downgrade_cost: int(int32), existing_static_apps: str, spec: any} # A JSON object.
@errors {401, 429, 500}

@endpoint GET /v2/apps/regions
@desc List App Regions
@returns(200) {regions: [any]} # A JSON object with key `regions`
@errors {401, 429, 500}

@endpoint GET /v2/apps/tiers
@desc List App Tiers
@returns(200) {tiers: [map]} # A JSON object with a `tiers` key. This will be a list of all app tiers
@errors {401, 429, 500}

@endpoint GET /v2/apps/tiers/instance_sizes
@desc List Instance Sizes
@returns(200) {discount_percent: num(float), instance_sizes: [map]} # A JSON with key `instance_sizes`
@errors {401, 429, 500}

@endpoint GET /v2/apps/tiers/instance_sizes/{slug}
@desc Retrieve an Instance Size
@required {slug: str # The slug of the instance size}
@returns(200) {instance_size: any} # A JSON with key `instance_size`
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/tiers/{slug}
@desc Retrieve an App Tier
@required {slug: str # The slug of the tier}
@returns(200) {tier: any} # A JSON with the key `tier`
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/{app_id}/alerts
@desc List all app alerts
@returns(200) {alerts: [map]} # A JSON object with a `alerts` key. This is list of object `alerts`.
@errors {401, 404, 429, 500}

@endpoint POST /v2/apps/{app_id}/alerts/{alert_id}/destinations
@desc Update destinations for alerts
@required {alert_id: str # The alert ID}
@optional {emails: [any], slack_webhooks: [any]}
@returns(200) {alert: any} # A JSON object with an `alert` key. This is an object of type `alert`.
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/{app_id}/components/{component_name}/logs
@desc Retrieve Active Deployment Logs
@required {app_id: str # The app ID, component_name: str # An optional component name. If set, logs will be limited to this component only., type: str(UNSPECIFIED/BUILD/DEPLOY/RUN)=UNSPECIFIED # The type of logs to retrieve - BUILD: Build-time logs - DEPLOY: Deploy-time logs - RUN: Live run-time logs}
@optional {follow: bool # Whether the logs should follow live updates., pod_connection_timeout: str # An optional time duration to wait if the underlying component instance is not immediately available. Default: `3m`.}
@returns(200) {historic_urls: [str], live_url: str} # A JSON object with urls that point to archived logs
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/{app_id}/deployments
@desc List App Deployments
@returns(200) A JSON object with a `deployments` key. This will be a list of all app deployments
@errors {401, 404, 429, 500}

@endpoint POST /v2/apps/{app_id}/deployments
@desc Create an App Deployment
@optional {force_build: bool}
@returns(200) {deployment: any} # A JSON object with a `deployment` key.
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/{app_id}/deployments/{deployment_id}
@desc Retrieve an App Deployment
@required {deployment_id: str # The deployment ID}
@returns(200) A JSON of the requested deployment
@errors {401, 404, 429, 500}

@endpoint POST /v2/apps/{app_id}/deployments/{deployment_id}/cancel
@desc Cancel a Deployment
@returns(200) A JSON the `deployment` that was just cancelled.
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/{app_id}/deployments/{deployment_id}/components/{component_name}/logs
@desc Retrieve Deployment Logs
@returns(200)
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/{app_id}/deployments/{deployment_id}/logs
@desc Retrieve Aggregate Deployment Logs
@returns(200)
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/{app_id}/logs
@desc Retrieve Active Deployment Aggregate Logs
@returns(200)
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/{app_id}/metrics/bandwidth_daily
@desc Retrieve App Daily Bandwidth Metrics
@optional {date: str(date-time) # Optional day to query. Only the date component of the timestamp will be considered. Default: yesterday.}
@returns(200) {app_bandwidth_usage: [map], date: str(date-time)} # A JSON object with a `app_bandwidth_usage` key
@errors {401, 404, 429, 500}

@endpoint POST /v2/apps/{app_id}/rollback
@desc Rollback App
@optional {deployment_id: str # The ID of the deployment to rollback to., skip_pin: bool # Whether to skip pinning the rollback deployment. If false, the rollback deployment will be pinned and any new deployments including Auto Deploy on Push hooks will be disabled until the rollback is either manually committed or reverted via the CommitAppRollback or RevertAppRollback endpoints respectively. If true, the rollback will be immediately committed and the app will remain unpinned.}
@returns(200)
@errors {401, 404, 429, 500}

@endpoint POST /v2/apps/{app_id}/rollback/commit
@desc Commit App Rollback
@returns(200)
@errors {401, 404, 429, 500}

@endpoint POST /v2/apps/{app_id}/rollback/revert
@desc Revert App Rollback
@returns(200)
@errors {401, 404, 429, 500}

@endpoint POST /v2/apps/{app_id}/rollback/validate
@desc Validate App Rollback
@returns(200) {error: any, valid: bool, warnings: [any]} # A JSON object with the validation results.
@errors {401, 404, 429, 500}

@endpoint DELETE /v2/apps/{id}
@desc Delete an App
@required {id: str # The ID of the app}
@returns(200) {id: str} # the ID of the app deleted.
@errors {401, 404, 429, 500}

@endpoint GET /v2/apps/{id}
@desc Retrieve an Existing App
@optional {name: str # The name of the app to retrieve.}
@returns(200) A JSON with key `app`
@errors {401, 404, 429, 500}

@endpoint PUT /v2/apps/{id}
@desc Update an App
@required {spec: any}
@returns(200) A JSON object of the updated `app`
@errors {401, 404, 429, 500}

@endpoint GET /v2/cdn/endpoints
@desc List All CDN Endpoints
@returns(200) The result will be a JSON object with an `endpoints` key. This will be set to an array of endpoint objects, each of which will contain the standard CDN endpoint attributes.
@errors {401, 429, 500}

@endpoint POST /v2/cdn/endpoints
@desc Create a New CDN Endpoint
@returns(201) {endpoint: any} # The response will be a JSON object with an `endpoint` key. This will be set to an object containing the standard CDN endpoint attributes.
@errors {401, 429, 500}

@endpoint DELETE /v2/cdn/endpoints/{cdn_id}
@desc Delete a CDN Endpoint
@returns(204)
@errors {401, 404, 429, 500}

@endpoint GET /v2/cdn/endpoints/{cdn_id}
@desc Retrieve an Existing CDN Endpoint
@required {cdn_id: str(uuid) # A unique identifier for a CDN endpoint.}
@returns(200)
@errors {401, 404, 429, 500}

@endpoint PUT /v2/cdn/endpoints/{cdn_id}
@desc Update a CDN Endpoint
@optional {certificate_id: str(uuid) # The ID of a DigitalOcean managed TLS certificate used for SSL when a custom subdomain is provided., custom_domain: str(hostname) # The fully qualified domain name (FQDN) of the custom subdomain used with the CDN endpoint., ttl: int(60/600/3600/86400/604800)=3600 # The amount of time the content is cached by the CDN's edge servers in seconds. TTL must be one of 60, 600, 3600, 86400, or 604800. Defaults to 3600 (one hour) when excluded.}
@returns(200)
@errors {401, 404, 429, 500}

@endpoint DELETE /v2/cdn/endpoints/{cdn_id}/cache
@desc Purge the Cache for an Existing CDN Endpoint
@required {files: [str] # An array of strings containing the path to the content to be purged from the CDN cache.}
@returns(204)
@errors {401, 404, 429, 500}

@endpoint GET /v2/certificates
@desc List All Certificates
@returns(200) The result will be a JSON object with a `certificates` key. This will be set to an array of certificate objects, each of which will contain the standard certificate attributes.
@errors {401, 429, 500}

@endpoint POST /v2/certificates
@desc Create a New Certificate
@returns(201) {certificate: any} # The response will be a JSON object with a key called `certificate`. The value of this will be an object that contains the standard attributes associated with a certificate.
When using Let's Encrypt, the initial value of the certificate's `state` attribute will be `pending`. When the certificate has been successfully issued by Let's Encrypt, this will transition to `verified` and be ready for use.
@errors {401, 429, 500}

@endpoint DELETE /v2/certificates/{certificate_id}
@desc Delete a Certificate
@returns(204)
@errors {401, 404, 429, 500}

@endpoint GET /v2/certificates/{certificate_id}
@desc Retrieve an Existing Certificate
@required {certificate_id: str(uuid) # A unique identifier for a certificate.}
@returns(200) {certificate: any} # The response will be a JSON object with a `certificate` key. This will be set to an object containing the standard certificate attributes.
@errors {401, 404, 429, 500}

@endpoint GET /v2/customers/my/balance
@desc Get Customer Balance
@returns(200) {account_balance: str, generated_at: str(date-time), month_to_date_balance: str, month_to_date_usage: str} # The response will be a JSON object that contains the following attributes
@errors {401, 404, 429, 500}

@endpoint GET /v2/customers/my/billing_history
@desc List Billing History
@returns(200) The response will be a JSON object that contains the following attributes
@errors {401, 404, 429, 500}

@endpoint GET /v2/customers/my/invoices
@desc List All Invoices
@returns(200) The response will be a JSON object contains that contains a list of invoices under the `invoices` key, and the invoice preview under the `invoice_preview` key.
Each element contains the invoice summary attributes.
@errors {401, 429, 500}

@endpoint GET /v2/customers/my/invoices/{invoice_uuid}
@desc Retrieve an Invoice by UUID
@required {invoice_uuid: str # UUID of the invoice}
@returns(200) The response will be a JSON object with a key called `invoice_items`. This will be set to an array of invoice item objects.
@errors {401, 404, 429, 500}

@endpoint GET /v2/customers/my/invoices/{invoice_uuid}/csv
@desc Retrieve an Invoice CSV by UUID
@returns(200) The response will be a CSV file.
@errors {401, 404, 429, 500}

@endpoint GET /v2/customers/my/invoices/{invoice_uuid}/pdf
@desc Retrieve an Invoice PDF by UUID
@returns(200) The response will be a PDF file.
@errors {401, 404, 429, 500}

@endpoint GET /v2/customers/my/invoices/{invoice_uuid}/summary
@desc Retrieve an Invoice Summary by UUID
@returns(200) {amount: str, billing_period: str, credits_and_adjustments: any, invoice_uuid: str, overages: any, product_charges: any, taxes: any, user_billing_address: any, user_company: str, user_email: str, user_name: str} # To retrieve a summary for an invoice, send a GET request to  `/v2/customers/my/invoices/$INVOICE_UUID/summary`.
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases
@desc List All Database Clusters
@optional {tag_name: str # Limits the results to database clusters with a specific tag.}
@returns(200) {databases: [map]} # A JSON object with a key of `databases`.
@errors {401, 404, 429, 500}

@endpoint POST /v2/databases
@desc Create a New Database Cluster
@returns(201) {database: any} # A JSON object with a key of `database`.
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases/options
@desc List Database Options
@returns(200) {options: map{mongodb: any, mysql: any, pg: any, redis: any}, version_availability: map{mongodb: any, mysql: any, pg: [map], redis: any}} # A JSON string with a key of `options`.
@errors {401, 404, 429, 500}

@endpoint DELETE /v2/databases/{database_cluster_uuid}
@desc Destroy a Database Cluster
@returns(204)
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases/{database_cluster_uuid}
@desc Retrieve an Existing Database Cluster
@required {database_cluster_uuid: str(uuid) # A unique identifier for a database cluster.}
@returns(200)
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases/{database_cluster_uuid}/backups
@desc List Backups for a Database Cluster
@returns(200) {backups: [map]} # A JSON object with a key of `database_backups`.
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases/{database_cluster_uuid}/ca
@desc Retrieve the Public Certificate
@returns(200) {ca: map{certificate: str}} # A JSON object with a key of `ca`.
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases/{database_cluster_uuid}/config
@desc Retrieve an Existing Database Cluster Configuration
@returns(200) {config: any} # A JSON object with a key of `config`.
@errors {401, 404, 429, 500}

@endpoint PATCH /v2/databases/{database_cluster_uuid}/config
@desc Update the Database Configuration for an Existing Database
@optional {config: any}
@returns(204)
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases/{database_cluster_uuid}/dbs
@desc List All Databases
@returns(200) {dbs: [map]} # A JSON object with a key of `databases`.
@errors {401, 404, 429, 500}

@endpoint POST /v2/databases/{database_cluster_uuid}/dbs
@desc Add a New Database
@returns(201) {db: any} # A JSON object with a key of `db`.
@errors {401, 404, 429, 500}

@endpoint DELETE /v2/databases/{database_cluster_uuid}/dbs/{database_name}
@desc Delete a Database
@returns(204)
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases/{database_cluster_uuid}/dbs/{database_name}
@desc Retrieve an Existing Database
@required {database_name: str # The name of the database.}
@returns(200)
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases/{database_cluster_uuid}/eviction_policy
@desc Retrieve the Eviction Policy for a Redis Cluster
@returns(200) {eviction_policy: any} # A JSON string with a key of `eviction_policy`.
@errors {401, 404, 429, 500}

@endpoint PUT /v2/databases/{database_cluster_uuid}/eviction_policy
@desc Configure the Eviction Policy for a Redis Cluster
@required {eviction_policy: any}
@returns(204)
@errors {401, 404, 429, 500}

@endpoint GET /v2/databases/{database_cluster_uuid}/firewall
@desc List Firewall Rules (Trusted Sources) for a Database Cluster
@returns(200) {rules: [any]} # A JSON object with a key of `rules`.
@errors {401, 404, 429, 500}

