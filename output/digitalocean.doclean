@endpoint GET /v2/uptime/checks/{check_id}/state
@desc Retrieve Check State
@returns(200) {state: map{previous_outage: map{duration_seconds: int, ended_at: str, region: str, started_at: str}, regions: map{eu_west: any, us_east: map}}} # The response will be a JSON object with a key called `state`. The value of this will be an object that contains the standard attributes associated with an uptime check's state.
