@desc Get a single project issue
@required {id: any # The ID of a project, issue_id: any # The ID of a project issue}
@returns(200) Get a single project issue

@endpoint PUT /v3/projects/{id}/issues/{issue_id}
@desc Update an existing issue
@required {id: any # The ID of a project, issue_id: any # The ID of a project issue}
@optional {title: any # The title of an issue, updated_at: any # Date time when the issue was updated. Available only for admins and project owners., state_event: any # State of the issue, description: any # The description of an issue, assignee_id: any # The ID of a user to assign issue, milestone_id: any # The ID of a milestone to assign issue, labels: any # Comma-separated list of label names, due_date: any # Date time string in the format YEAR-MONTH-DAY, confidential: any # Boolean parameter if the issue should be confidential, created_at: any}
@returns(200) Update an existing issue

