@endpoint GET /v3/application/settings
@desc Get the current application settings
@returns(200) Get the current application settings

@endpoint PUT /v3/application/settings
@desc Modify application settings
@required {domain_blacklist: any # Users with e-mail addresses that match these domain(s) will NOT be able to sign-up. Wildcards allowed. Use separate lines for multiple entries. Ex: domain.com, *.domain.com, two_factor_grace_period: any # Amount of time (in hours) that users are allowed to skip forced configuration of two-factor authentication, shared_runners_text: any # Shared runners text, metrics_host: any # The InfluxDB host, metrics_port: any # The UDP port to use for connecting to InfluxDB, metrics_pool_size: any # The amount of InfluxDB connections to open, metrics_timeout: any # The amount of seconds after which an InfluxDB connection will time out, metrics_method_call_threshold: any # A method call is only tracked when it takes longer to complete than the given amount of milliseconds., metrics_sample_interval: any # The sampling interval in seconds, metrics_packet_size: any # The amount of points to store in a single UDP packet, sidekiq_throttling_queus: any # Choose which queues you wish to throttle, sidekiq_throttling_factor: any # The factor by which the queues should be throttled. A value between 0.0 and 1.0, exclusive., recaptcha_site_key: any # Generate site key at http://www.google.com/recaptcha, recaptcha_private_key: any # Generate private key at http://www.google.com/recaptcha, akismet_api_key: any # Generate API key at http://www.akismet.com, sentry_dsn: any # Sentry Data Source Name, koding_url: any # The Koding team URL, plantuml_url: any # The PlantUML server URL, housekeeping_bitmaps_enabled: any # Creating pack file bitmaps makes housekeeping take a little longer but bitmaps should accelerate 'git clone' performance., housekeeping_incremental_repack_period: any # Number of Git pushes after which an incremental 'git repack' is run., housekeeping_full_repack_period: any # Number of Git pushes after which a full 'git repack' is run., housekeeping_gc_period: any # Number of Git pushes after which 'git gc' is run.}
@optional {default_branch_protection: any # Determine if developers can push to master, default_project_visibility: any # The default project visibility, default_snippet_visibility: any # The default snippet visibility, default_group_visibility: any # The default group visibility, restricted_visibility_levels: any # Selected levels cannot be used by non-admin users for projects or snippets. If the public level is restricted, user profiles are only visible to logged in users., import_sources: any # Enabled sources for code import during project creation. OmniAuth must be configured for GitHub, Bitbucket, and GitLab.com, disabled_oauth_sign_in_sources: any # Disable certain OAuth sign-in sources, enabled_git_access_protocol: any # Allow only the selected protocols to be used for Git access., gravatar_enabled: any # Flag indicating if the Gravatar service is enabled, default_projects_limit: any # The maximum number of personal projects, max_attachment_size: any # Maximum attachment size in MB, session_expire_delay: any # Session duration in minutes. GitLab restart is required to apply changes., user_oauth_applications: any # Allow users to register any application to use GitLab as an OAuth provider, user_default_external: any # Newly registered users will by default be external, signup_enabled: any # Flag indicating if sign up is enabled, send_user_confirmation_email: any # Send confirmation email on sign-up, domain_whitelist: any # ONLY users with e-mail addresses that match these domain(s) will be able to sign-up. Wildcards allowed. Use separate lines for multiple entries. Ex: domain.com, *.domain.com, domain_blacklist_enabled: any # Enable domain blacklist for sign ups, after_sign_up_text: any # Text shown after sign up, signin_enabled: any # Flag indicating if sign in is enabled, require_two_factor_authentication: any # Require all users to setup Two-factor authentication, home_page_url: any # We will redirect non-logged in users to this page, after_sign_out_path: any # We will redirect users to this page after they sign out, sign_in_text: any # The sign in text of the GitLab application, help_page_text: any # Custom text displayed on the help page, shared_runners_enabled: any # Enable shared runners for new projects, max_artifacts_size: any # Set the maximum file size each build's artifacts can have, container_registry_token_expire_delay: any # Authorization token duration (minutes), metrics_enabled: any # Enable the InfluxDB metrics, sidekiq_throttling_enabled: any # Enable Sidekiq Job Throttling, recaptcha_enabled: any # Helps prevent bots from creating accounts, akismet_enabled: any # Helps prevent bots from creating issues, admin_notification_email: any # Abuse reports will be sent to this address if it is set. Abuse reports are always available in the admin area., sentry_enabled: any # Sentry is an error reporting and logging tool which is currently not shipped with GitLab, get it here: https://getsentry.com, repository_storage: any # Storage paths for new projects, repository_checks_enabled: any # GitLab will periodically run 'git fsck' in all project and wiki repositories to look for silent disk corruption issues., koding_enabled: any # Enable Koding, plantuml_enabled: any # Enable PlantUML, version_check_enabled: any # Let GitLab inform you when an update is available., email_author_in_body: any # Some email servers do not support overriding the email sender name. Enable this option to include the name of the author of the issue, merge request or comment in the email body instead., html_emails_enabled: any # By default GitLab sends emails in HTML and plain text formats so mail clients can choose what format to use. Disable this option if you only want to send emails in plain text format., housekeeping_enabled: any # Enable automatic repository housekeeping (git repack, git gc)}
@returns(200) Modify application settings

@endpoint POST /v3/ci/lint
@desc Validation of .gitlab-ci.yml content
@required {content: any # Content of .gitlab-ci.yml}
@returns(201) Validation of .gitlab-ci.yml content

@endpoint GET /v3/deploy_keys
@returns(200) get DeployKey(s)

@endpoint GET /v3/dockerfiles
@desc Get the list of the available template
@returns(200) Get the list of the available template

@endpoint GET /v3/dockerfiles/{name}
@desc Get the text for a specific template present in local filesystem
@required {name: any # The name of the template}
@returns(200) Get the text for a specific template present in local filesystem

@endpoint GET /v3/gitignores
@desc Get the list of the available template
@returns(200) Get the list of the available template

@endpoint GET /v3/gitignores/{name}
@desc Get the text for a specific template present in local filesystem
@required {name: any # The name of the template}
@returns(200) Get the text for a specific template present in local filesystem

@endpoint GET /v3/gitlab_ci_ymls
@desc Get the list of the available template
@returns(200) Get the list of the available template

@endpoint GET /v3/gitlab_ci_ymls/{name}
@desc Get the text for a specific template present in local filesystem
@required {name: any # The name of the template}
@returns(200) Get the text for a specific template present in local filesystem

@endpoint GET /v3/groups
@desc Get a groups list
@optional {statistics: any # Include project statistics, skip_groups: any # Array of group ids to exclude from list, all_available: any # Show all group that you have access to, search: any # Search for a specific group, order_by: any # Order by name or path, sort: any # Sort by asc (ascending) or desc (descending), page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Get a groups list

@endpoint POST /v3/groups
@desc Create a group. Available only for users who can create groups.
@required {name: any # The name of the group, path: any # The path of the group}
@optional {description: any # The description of the group, visibility_level: any # The visibility level of the group, lfs_enabled: any # Enable/disable LFS for the projects in this group, request_access_enabled: any # Allow users to request member access}
@returns(201) Create a group. Available only for users who can create groups.

@endpoint GET /v3/groups/owned
@desc Get list of owned groups for authenticated user
@optional {page: any # Current page number, per_page: any # Number of items per page, statistics: any # Include project statistics}
@returns(200) Get list of owned groups for authenticated user

@endpoint DELETE /v3/groups/{id}
@desc Remove a group.
@required {id: any # The ID of a group}
@returns(204) Remove a group.

@endpoint GET /v3/groups/{id}
@desc Get a single group, with containing projects.
@required {id: any # The ID of a group}
@returns(200) Get a single group, with containing projects.

@endpoint PUT /v3/groups/{id}
@desc Update a group. Available only for users who can administrate groups.
@required {id: any # The ID of a group}
@optional {name: any # The name of the group, path: any # The path of the group, description: any # The description of the group, visibility_level: any # The visibility level of the group, lfs_enabled: any # Enable/disable LFS for the projects in this group, request_access_enabled: any # Allow users to request member access}
@returns(200) Update a group. Available only for users who can administrate groups.

@endpoint GET /v3/groups/{id}/access_requests
@desc Gets a list of access requests for a group.
@required {id: any # The group ID}
@optional {page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Gets a list of access requests for a group.

@endpoint POST /v3/groups/{id}/access_requests
@desc Requests access for the authenticated user to a group.
@required {id: any # The group ID}
@returns(201) Requests access for the authenticated user to a group.

@endpoint DELETE /v3/groups/{id}/access_requests/{user_id}
@desc Denies an access request for the given user.
@required {id: any # The group ID, user_id: any # The user ID of the access requester}
@returns(204) Denies an access request for the given user.

@endpoint PUT /v3/groups/{id}/access_requests/{user_id}/approve
@desc Approves an access request for the given user.
@required {id: any # The group ID, user_id: any # The user ID of the access requester}
@optional {access_level: any # A valid access level (defaults: `30`, developer access level)}
@returns(200) Approves an access request for the given user.

@endpoint GET /v3/groups/{id}/issues
@desc Get a list of group issues
@required {id: any # The ID of a group}
@optional {state: any # Return opened, closed, or all issues, labels: any # Comma-separated list of label names, milestone: any # Return issues for a specific milestone, order_by: any # Return issues ordered by `created_at` or `updated_at` fields., sort: any # Return issues sorted in `asc` or `desc` order., page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Get a list of group issues

@endpoint GET /v3/groups/{id}/members
@desc Gets a list of group or project members viewable by the authenticated user.
@required {id: any # The group ID}
@optional {query: any # A query string to search for members, page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Gets a list of group or project members viewable by the authenticated user.

@endpoint POST /v3/groups/{id}/members
@desc Adds a member to a group or project.
@required {id: any # The group ID, user_id: any # The user ID of the new member, access_level: any # A valid access level (defaults: `30`, developer access level)}
@optional {expires_at: any # Date string in the format YEAR-MONTH-DAY}
@returns(201) Adds a member to a group or project.

@endpoint DELETE /v3/groups/{id}/members/{user_id}
@desc Removes a user from a group or project.
@required {id: any # The group ID, user_id: any # The user ID of the member}
@returns(204) Removes a user from a group or project.

@endpoint GET /v3/groups/{id}/members/{user_id}
@desc Gets a member of a group or project.
@required {id: any # The group ID, user_id: any # The user ID of the member}
@returns(200) Gets a member of a group or project.

@endpoint PUT /v3/groups/{id}/members/{user_id}
@desc Updates a member of a group or project.
@required {id: any # The group ID, user_id: any # The user ID of the new member, access_level: any # A valid access level}
@optional {expires_at: any # Date string in the format YEAR-MONTH-DAY}
@returns(200) Updates a member of a group or project.

@endpoint GET /v3/groups/{id}/notification_settings
@desc Get group level notification level settings, defaults to Global
@required {id: any # The group ID or project ID or project NAMESPACE/PROJECT_NAME}
@returns(200) Get group level notification level settings, defaults to Global

@endpoint PUT /v3/groups/{id}/notification_settings
@desc Update group level notification level settings, defaults to Global
@required {id: any # The group ID or project ID or project NAMESPACE/PROJECT_NAME}
@optional {level: any # The group notification level, new_note: any # Enable/disable this notification, new_issue: any # Enable/disable this notification, reopen_issue: any # Enable/disable this notification, close_issue: any # Enable/disable this notification, reassign_issue: any # Enable/disable this notification, new_merge_request: any # Enable/disable this notification, reopen_merge_request: any # Enable/disable this notification, close_merge_request: any # Enable/disable this notification, reassign_merge_request: any # Enable/disable this notification, merge_merge_request: any # Enable/disable this notification, failed_pipeline: any # Enable/disable this notification, success_pipeline: any # Enable/disable this notification}
@returns(200) Update group level notification level settings, defaults to Global

@endpoint GET /v3/groups/{id}/projects
@desc Get a list of projects in this group.
@required {id: any # The ID of a group}
@optional {archived: any # Limit by archived status, visibility: any # Limit by visibility, search: any # Return list of authorized projects matching the search criteria, order_by: any # Return projects ordered by field, sort: any # Return projects sorted in ascending and descending order, simple: any # Return only the ID, URL, name, and path of each project, page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Get a list of projects in this group.

@endpoint POST /v3/groups/{id}/projects/{project_id}
@desc Transfer a project to the group namespace. Available only for admin.
@required {id: any # The ID of a group, project_id: any # The ID or path of the project}
@returns(201) Transfer a project to the group namespace. Available only for admin.

@endpoint GET /v3/hooks
@desc Get the list of system hooks
@returns(200) Get the list of system hooks

@endpoint POST /v3/hooks
@desc Create a new system hook
@required {url: any # The URL to send the request to}
@optional {token: any # The token used to validate payloads, push_events: any # Trigger hook on push events, tag_push_events: any # Trigger hook on tag push events, enable_ssl_verification: any # Do SSL verification when triggering the hook}
@returns(201) Create a new system hook

@endpoint DELETE /v3/hooks/{id}
@desc Delete a hook
@required {id: any # The ID of the system hook}
@returns(200) Delete a hook

@endpoint GET /v3/hooks/{id}
@desc Test a hook
@required {id: any # The ID of the system hook}
@returns(200) Test a hook

@endpoint POST /v3/internal/allowed
@returns(201) created Allowed

@endpoint GET /v3/internal/broadcast_message
@returns(200) get BroadcastMessage(s)

@endpoint GET /v3/internal/check
@returns(200) get Check(s)

@endpoint GET /v3/internal/discover
@returns(200) get Discover(s)

@endpoint POST /v3/internal/lfs_authenticate
@returns(201) created LfsAuthenticate

@endpoint GET /v3/internal/merge_request_urls
@returns(200) get MergeRequestUrl(s)

@endpoint POST /v3/internal/two_factor_recovery_codes
@returns(201) created TwoFactorRecoveryCode

@endpoint GET /v3/issues
@desc Get currently authenticated user's issues
@optional {state: any # Return opened, closed, or all issues, labels: any # Comma-separated list of label names, milestone: any # Return issues for a specific milestone, order_by: any # Return issues ordered by `created_at` or `updated_at` fields., sort: any # Return issues sorted in `asc` or `desc` order., page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Get currently authenticated user's issues

@endpoint GET /v3/keys/{id}
@desc Get single ssh key by id. Only available to admin users
@required {id: any}
@returns(200) Get single ssh key by id. Only available to admin users

@endpoint GET /v3/licenses
@desc Get the list of the available license template
@optional {popular: any # If passed, returns only popular licenses}
@returns(200) Get the list of the available license template

@endpoint GET /v3/licenses/{name}
@desc Get the text for a specific license
@required {name: any # The name of the template}
@returns(200) Get the text for a specific license

@endpoint GET /v3/namespaces
@desc Get a namespaces list
@optional {search: any # Search query for namespaces, page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Get a namespaces list

@endpoint GET /v3/notification_settings
@desc Get global notification level settings and email, defaults to Participate
@returns(200) Get global notification level settings and email, defaults to Participate

@endpoint PUT /v3/notification_settings
@desc Update global notification level settings and email, defaults to Participate
@optional {level: any # The global notification level, notification_email: any # The email address to send notifications, new_note: any # Enable/disable this notification, new_issue: any # Enable/disable this notification, reopen_issue: any # Enable/disable this notification, close_issue: any # Enable/disable this notification, reassign_issue: any # Enable/disable this notification, new_merge_request: any # Enable/disable this notification, reopen_merge_request: any # Enable/disable this notification, close_merge_request: any # Enable/disable this notification, reassign_merge_request: any # Enable/disable this notification, merge_merge_request: any # Enable/disable this notification, failed_pipeline: any # Enable/disable this notification, success_pipeline: any # Enable/disable this notification}
@returns(200) Update global notification level settings and email, defaults to Participate

@endpoint GET /v3/projects
@desc Get a projects list for authenticated user
@optional {order_by: any # Return projects ordered by field, sort: any # Return projects sorted in ascending and descending order, archived: any # Limit by archived status, visibility: any # Limit by visibility, search: any # Return list of authorized projects matching the search criteria, page: any # Current page number, per_page: any # Number of items per page, simple: any # Return only the ID, URL, name, and path of each project}
@returns(200) Get a projects list for authenticated user

@endpoint POST /v3/projects
@desc Create new project
@required {name: any # The name of the project}
@optional {path: any # The path of the repository, description: any # The description of the project, issues_enabled: any # Flag indication if the issue tracker is enabled, merge_requests_enabled: any # Flag indication if merge requests are enabled, wiki_enabled: any # Flag indication if the wiki is enabled, builds_enabled: any # Flag indication if builds are enabled, snippets_enabled: any # Flag indication if snippets are enabled, shared_runners_enabled: any # Flag indication if shared runners are enabled for that project, container_registry_enabled: any # Flag indication if the container registry is enabled for that project, lfs_enabled: any # Flag indication if Git LFS is enabled for that project, public: any # Create a public project. The same as visibility_level = 20., visibility_level: any # Create a public project. The same as visibility_level = 20., public_builds: any # Perform public builds, request_access_enabled: any # Allow users to request member access, only_allow_merge_if_build_succeeds: any # Only allow to merge if builds succeed, only_allow_merge_if_all_discussions_are_resolved: any # Only allow to merge if all discussions are resolved, namespace_id: any # Namespace ID for the new project. Default to the user namespace., import_url: any # URL from which the project is imported}
@returns(201) Create new project

@endpoint GET /v3/projects/all
@desc Get all projects for admin user
@optional {order_by: any # Return projects ordered by field, sort: any # Return projects sorted in ascending and descending order, archived: any # Limit by archived status, visibility: any # Limit by visibility, search: any # Return list of authorized projects matching the search criteria, page: any # Current page number, per_page: any # Number of items per page, simple: any # Return only the ID, URL, name, and path of each project, statistics: any # Include project statistics}
@returns(200) Get all projects for admin user

@endpoint POST /v3/projects/fork/{id}
@desc Fork new project for the current user or provided namespace.
@required {id: any # The ID of a project}
@optional {namespace: any # The ID or name of the namespace that the project will be forked into}
@returns(201) Fork new project for the current user or provided namespace.

@endpoint GET /v3/projects/owned
@desc Get an owned projects list for authenticated user
@optional {order_by: any # Return projects ordered by field, sort: any # Return projects sorted in ascending and descending order, archived: any # Limit by archived status, visibility: any # Limit by visibility, search: any # Return list of authorized projects matching the search criteria, page: any # Current page number, per_page: any # Number of items per page, simple: any # Return only the ID, URL, name, and path of each project, statistics: any # Include project statistics}
@returns(200) Get an owned projects list for authenticated user

@endpoint GET /v3/projects/search/{query}
@desc Search for projects the current user has access to
@required {query: any # The project name to be searched}
@optional {order_by: any # Return projects ordered by field, sort: any # Return projects sorted in ascending and descending order, page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Search for projects the current user has access to

@endpoint GET /v3/projects/starred
@desc Gets starred project for the authenticated user
@optional {order_by: any # Return projects ordered by field, sort: any # Return projects sorted in ascending and descending order, archived: any # Limit by archived status, visibility: any # Limit by visibility, search: any # Return list of authorized projects matching the search criteria, page: any # Current page number, per_page: any # Number of items per page, simple: any # Return only the ID, URL, name, and path of each project}
@returns(200) Gets starred project for the authenticated user

@endpoint POST /v3/projects/user/{user_id}
@desc Create new project for a specified user. Only available to admin users.
@required {name: any # The name of the project, user_id: any # The ID of a user}
@optional {default_branch: any # The default branch of the project, description: any # The description of the project, issues_enabled: any # Flag indication if the issue tracker is enabled, merge_requests_enabled: any # Flag indication if merge requests are enabled, wiki_enabled: any # Flag indication if the wiki is enabled, builds_enabled: any # Flag indication if builds are enabled, snippets_enabled: any # Flag indication if snippets are enabled, shared_runners_enabled: any # Flag indication if shared runners are enabled for that project, container_registry_enabled: any # Flag indication if the container registry is enabled for that project, lfs_enabled: any # Flag indication if Git LFS is enabled for that project, public: any # Create a public project. The same as visibility_level = 20., visibility_level: any # Create a public project. The same as visibility_level = 20., public_builds: any # Perform public builds, request_access_enabled: any # Allow users to request member access, only_allow_merge_if_build_succeeds: any # Only allow to merge if builds succeed, only_allow_merge_if_all_discussions_are_resolved: any # Only allow to merge if all discussions are resolved, namespace_id: any # Namespace ID for the new project. Default to the user namespace., import_url: any # URL from which the project is imported}
@returns(201) Create new project for a specified user. Only available to admin users.

@endpoint GET /v3/projects/visible
@desc Get a list of visible projects for authenticated user
@optional {order_by: any # Return projects ordered by field, sort: any # Return projects sorted in ascending and descending order, archived: any # Limit by archived status, visibility: any # Limit by visibility, search: any # Return list of authorized projects matching the search criteria, page: any # Current page number, per_page: any # Number of items per page, simple: any # Return only the ID, URL, name, and path of each project}
@returns(200) Get a list of visible projects for authenticated user

@endpoint DELETE /v3/projects/{id}
@desc Remove a project
@required {id: any # The ID of a project}
@returns(204) Remove a project

@endpoint GET /v3/projects/{id}
@desc Get a single project
@required {id: any # The ID of a project}
@returns(200) Get a single project

@endpoint PUT /v3/projects/{id}
@desc Update an existing project
@required {id: any # The ID of a project}
@optional {name: any # The name of the project, default_branch: any # The default branch of the project, path: any # The path of the repository, description: any # The description of the project, issues_enabled: any # Flag indication if the issue tracker is enabled, merge_requests_enabled: any # Flag indication if merge requests are enabled, wiki_enabled: any # Flag indication if the wiki is enabled, builds_enabled: any # Flag indication if builds are enabled, snippets_enabled: any # Flag indication if snippets are enabled, shared_runners_enabled: any # Flag indication if shared runners are enabled for that project, container_registry_enabled: any # Flag indication if the container registry is enabled for that project, lfs_enabled: any # Flag indication if Git LFS is enabled for that project, public: any # Create a public project. The same as visibility_level = 20., visibility_level: any # Create a public project. The same as visibility_level = 20., public_builds: any # Perform public builds, request_access_enabled: any # Allow users to request member access, only_allow_merge_if_build_succeeds: any # Only allow to merge if builds succeed, only_allow_merge_if_all_discussions_are_resolved: any # Only allow to merge if all discussions are resolved}
@returns(200) Update an existing project

@endpoint POST /v3/projects/{id}/(ref/{ref}/)trigger/builds
@desc Trigger a GitLab project build
@required {id: any # The ID of a project, ref: any # The commit sha or name of a branch or tag, token: any # The unique token of trigger}
@returns(201) Trigger a GitLab project build

@endpoint GET /v3/projects/{id}/access_requests
@desc Gets a list of access requests for a project.
@required {id: any # The project ID}
@optional {page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Gets a list of access requests for a project.

@endpoint POST /v3/projects/{id}/access_requests
@desc Requests access for the authenticated user to a project.
@required {id: any # The project ID}
@returns(201) Requests access for the authenticated user to a project.

@endpoint DELETE /v3/projects/{id}/access_requests/{user_id}
@desc Denies an access request for the given user.
@required {id: any # The project ID, user_id: any # The user ID of the access requester}
@returns(204) Denies an access request for the given user.

@endpoint PUT /v3/projects/{id}/access_requests/{user_id}/approve
@desc Approves an access request for the given user.
@required {id: any # The project ID, user_id: any # The user ID of the access requester}
@optional {access_level: any # A valid access level (defaults: `30`, developer access level)}
@returns(200) Approves an access request for the given user.

@endpoint POST /v3/projects/{id}/archive
@desc Archive a project
@required {id: any # The ID of a project}
@returns(201) Archive a project

@endpoint GET /v3/projects/{id}/boards
@desc Get all project boards
@required {id: any # The ID of a project}
@returns(200) Get all project boards

@endpoint GET /v3/projects/{id}/boards/{board_id}/lists
@desc Get the lists of a project board
@required {id: any # The ID of a project, board_id: any # The ID of a board}
@returns(200) Get the lists of a project board

@endpoint POST /v3/projects/{id}/boards/{board_id}/lists
@desc Create a new board list
@required {id: any # The ID of a project, board_id: any # The ID of a board, label_id: any # The ID of an existing label}
