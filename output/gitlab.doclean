@desc Get project hooks
@required {id: any # The ID of a project}
@optional {page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Get project hooks

@endpoint POST /v3/projects/{id}/hooks
@desc Add hook to project
@required {id: any # The ID of a project, url: any # The URL to send the request to}
@optional {push_events: any # Trigger hook on push events, issues_events: any # Trigger hook on issues events, merge_requests_events: any # Trigger hook on merge request events, tag_push_events: any # Trigger hook on tag push events, note_events: any # Trigger hook on note(comment) events, build_events: any # Trigger hook on build events, pipeline_events: any # Trigger hook on pipeline events, wiki_page_events: any # Trigger hook on wiki events, enable_ssl_verification: any # Do SSL verification when triggering the hook, token: any # Secret token to validate received payloads; this will not be returned in the response}
@returns(201) Add hook to project

@endpoint DELETE /v3/projects/{id}/hooks/{hook_id}
@desc Deletes project hook
@required {id: any # The ID of a project, hook_id: any # The ID of the hook to delete}
@returns(200) Deletes project hook

@endpoint GET /v3/projects/{id}/hooks/{hook_id}
@desc Get a project hook
@required {id: any # The ID of a project, hook_id: any # The ID of a project hook}
@returns(200) Get a project hook

@endpoint PUT /v3/projects/{id}/hooks/{hook_id}
@desc Update an existing project hook
@required {id: any # The ID of a project, hook_id: any # The ID of the hook to update, url: any # The URL to send the request to}
@optional {push_events: any # Trigger hook on push events, issues_events: any # Trigger hook on issues events, merge_requests_events: any # Trigger hook on merge request events, tag_push_events: any # Trigger hook on tag push events, note_events: any # Trigger hook on note(comment) events, build_events: any # Trigger hook on build events, pipeline_events: any # Trigger hook on pipeline events, wiki_page_events: any # Trigger hook on wiki events, enable_ssl_verification: any # Do SSL verification when triggering the hook, token: any # Secret token to validate received payloads; this will not be returned in the response}
@returns(200) Update an existing project hook

@endpoint GET /v3/projects/{id}/issues
@desc Get a list of project issues
@required {id: any # The ID of a project}
@optional {state: any # Return opened, closed, or all issues, iid: any # Return the issue having the given `iid`, labels: any # Comma-separated list of label names, milestone: any # Return issues for a specific milestone, order_by: any # Return issues ordered by `created_at` or `updated_at` fields., sort: any # Return issues sorted in `asc` or `desc` order., page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Get a list of project issues

@endpoint POST /v3/projects/{id}/issues
@desc Create a new project issue
@required {id: any # The ID of a project, title: any # The title of an issue}
@optional {created_at: any # Date time when the issue was created. Available only for admins and project owners., merge_request_for_resolving_discussions: any # The IID of a merge request for which to resolve discussions, description: any # The description of an issue, assignee_id: any # The ID of a user to assign issue, milestone_id: any # The ID of a milestone to assign issue, labels: any # Comma-separated list of label names, due_date: any # Date time string in the format YEAR-MONTH-DAY, confidential: any # Boolean parameter if the issue should be confidential}
@returns(201) Create a new project issue

@endpoint DELETE /v3/projects/{id}/issues/{issue_id}
@desc Delete a project issue
@required {id: any # The ID of a project, issue_id: any # The ID of a project issue}
@returns(204) Delete a project issue

