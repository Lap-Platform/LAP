@endpoint GET /v3/projects/{id}/builds
@desc Get a project builds
@required {id: any # The ID of a project}
@optional {scope: any # The scope of builds to show, page: any # Current page number, per_page: any # Number of items per page}
@returns(200) Get a project builds

@endpoint GET /v3/projects/{id}/builds/artifacts/{ref_name}/download
@desc Download the artifacts file from build
