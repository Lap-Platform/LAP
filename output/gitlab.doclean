@endpoint PUT /v3/projects/{id}/boards/{board_id}/lists/{list_id}
@desc Moves a board list to a new position
@required {id: any # The ID of a project, board_id: any # The ID of a board, list_id: any # The ID of a list, position: any # The position of the list}
